@inject NavigationManager Navigation

<MudThemeProvider Theme="@KpgTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @{
                        var returnUrl = Uri.EscapeDataString(Navigation.Uri);
                        Navigation.NavigateTo($"/login?returnUrl={returnUrl}", replace: true);
                    }
                </NotAuthorized>
                <Authorizing>
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>

@code {
    private static readonly MudTheme KpgTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0D3B5E",
            Secondary = "#5BB8D4",
            Warning = "#FFD300",
            Info = "#F57C20",
            Success = "#2E7D32",
            Error = "#C62828",
            Background = "#F5F5F5",
            DrawerBackground = "#0D3B5E",
            DrawerText = "#FFFFFF",
            DrawerIcon = "#5BB8D4",
            AppbarBackground = "#0D3B5E",
            AppbarText = "#FFFFFF"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = ["Roboto", "sans-serif"], FontSize = "16px" },
            H1 = new H1Typography { FontFamily = ["Poppins", "sans-serif"] },
            H2 = new H2Typography { FontFamily = ["Poppins", "sans-serif"] },
            H3 = new H3Typography { FontFamily = ["Poppins", "sans-serif"] },
            H4 = new H4Typography { FontFamily = ["Poppins", "sans-serif"], FontSize = "24px", FontWeight = "600" },
            H5 = new H5Typography { FontFamily = ["Poppins", "sans-serif"], FontSize = "20px", FontWeight = "600" },
            H6 = new H6Typography { FontFamily = ["Poppins", "sans-serif"] },
            Body1 = new Body1Typography { FontFamily = ["Roboto", "sans-serif"], FontSize = "16px" },
            Body2 = new Body2Typography { FontFamily = ["Roboto", "sans-serif"], FontSize = "14px" },
            Caption = new CaptionTypography { FontFamily = ["Roboto", "sans-serif"], FontSize = "12px" },
