<MudPaper Class="pa-4" Elevation="2" Style="border-radius:12px;">
    <MudStack Spacing="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icon" Color="@Color" Size="Size.Medium" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Label</MudText>
        </MudStack>
        <MudText Typo="Typo.h4" Style="font-weight:700;">@Value</MudText>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = default!;
    [Parameter, EditorRequired] public int Value { get; set; }
    [Parameter, EditorRequired] public string Icon { get; set; } = default!;
    [Parameter] public Color Color { get; set; } = Color.Default;
}
