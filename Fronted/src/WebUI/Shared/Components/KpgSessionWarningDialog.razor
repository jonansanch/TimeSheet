@implements IDisposable

@if (Visible)
{
    <div style="position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999;
                display:flex; align-items:center; justify-content:center;">
        <MudPaper Elevation="8" Style="max-width:420px; width:100%; padding:32px; border-radius:12px;">

            <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
                <MudIcon Icon="@Icons.Material.Filled.AccessTime"
                         Color="Color.Warning" Size="Size.Large" />
                <MudText Typo="Typo.h6" Style="font-weight:600;">
                    Sesión por expirar
                </MudText>
            </div>

            <MudText Typo="Typo.body1" Class="mb-2">
                Tu sesión expirará en:
            </MudText>

            <MudText Typo="Typo.h4" Color="Color.Warning"
                     Style="font-weight:700; font-variant-numeric:tabular-nums; margin-bottom:20px;">
                @_countdown
            </MudText>

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
                ¿Deseas continuar trabajando o cerrar sesión?
            </MudText>

            <div style="display:flex; gap:12px; justify-content:flex-end;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           OnClick="OnLogout"
                           Disabled="_extending">
                    Cerrar sesión
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="OnContinue"
                           Disabled="_extending">
                    @if (_extending)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    }
                    Continuar
                </MudButton>
            </div>

        </MudPaper>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public DateTime ExpiresAt { get; set; }
    [Parameter] public EventCallback OnContinueClicked { get; set; }
    [Parameter] public EventCallback OnLogoutClicked { get; set; }

    private string _countdown = "--:--";
    private bool _extending;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;

    protected override void OnParametersSet()
    {
        if (Visible)
            StartCountdown();
        else
            StopCountdown();
    }

    private void StartCountdown()
    {
        StopCountdown();
        _cts = new CancellationTokenSource();
        _ = TickAsync(_cts.Token);
    }

    private void StopCountdown()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
        _timer?.Dispose();
        _timer = null;
    }

    private async Task TickAsync(CancellationToken ct)
    {
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await _timer.WaitForNextTickAsync(ct))
            {
                var remaining = ExpiresAt - DateTime.UtcNow;
                _countdown = remaining > TimeSpan.Zero
                    ? $"{(int)remaining.TotalMinutes:D2}:{remaining.Seconds:D2}"
                    : "00:00";
                await InvokeAsync(StateHasChanged);

                if (remaining <= TimeSpan.Zero)
                    break;
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task OnContinue()
    {
        _extending = true;
        StateHasChanged();
        await OnContinueClicked.InvokeAsync();
        _extending = false;
    }

    private async Task OnLogout()
    {
        await OnLogoutClicked.InvokeAsync();
    }

    public void Dispose() => StopCountdown();
}
