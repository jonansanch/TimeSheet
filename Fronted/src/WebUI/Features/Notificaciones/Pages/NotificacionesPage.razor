@page "/notificaciones"
@attribute [Authorize(Roles = $"{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")]
@inject INotificacionesRepository Repo
@inject IUserAdminRepository UsuariosRepo
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Notif_Title"] - KPG Timesheet</PageTitle>

<MudStack Spacing="4">

    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">@L["Notif_Title"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Notif_Subtitle"]</MudText>
    </div>

    <MudPaper Elevation="2" Class="pa-4" Style="border-radius:12px;">
        <MudGrid Spacing="2">

            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="@L["Notif_LabelFrom"]"
                               Date="_filtroDesdeDate"
                               DateChanged="d => _filtroDesde = d.HasValue ? DateOnly.FromDateTime(d.Value) : null"
                               MaxDate="DateTime.Today"
                               IsDateDisabledFunc="@(d => d.DayOfWeek == DayOfWeek.Sunday)"
                               PickerVariant="PickerVariant.Dialog"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               aria-label="@L["Notif_LabelFrom"]" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="@L["Notif_LabelTo"]"
                               Date="_filtroHastaDate"
                               DateChanged="d => _filtroHasta = d.HasValue ? DateOnly.FromDateTime(d.Value) : null"
                               MaxDate="DateTime.Today"
                               IsDateDisabledFunc="@(d => d.DayOfWeek == DayOfWeek.Sunday)"
                               PickerVariant="PickerVariant.Dialog"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               aria-label="@L["Notif_LabelTo"]" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           Label="@L["Label_Employee"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true"
                           Value="_filtroUserId"
                           ValueChanged="v => _filtroUserId = v"
                           aria-label="@L["Label_Employee"]">
                    @foreach (var u in _usuarios)
                    {
                        <MudSelectItem Value="@u.Id">@(u.NombreCompleto ?? u.Email)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="bool?"
                           Label="@L["Label_Status"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="_filtroSoloErrores"
                           ValueChanged="v => _filtroSoloErrores = v"
                           aria-label="@L["Label_Status"]">
                    <MudSelectItem T="bool?" Value="@((bool?)null)">@L["Notif_All"]</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">@L["Notif_SuccessOnly"]</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)true)">@L["Notif_ErrorsOnly"]</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           OnClick="BuscarAsync"
                           Disabled="_isLoading">
                    @L["Btn_Search"]
                </MudButton>
            </MudItem>

        </MudGrid>
    </MudPaper>

    @if (_isLoading)
    {
        <KpgTableSkeleton Rows="8" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
    }
    else if (_historial is not null)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudChip T="string" Color="Color.Primary" Size="Size.Small">
                @_historial.Total @L["Notif_TotalChip"]
            </MudChip>
        </MudStack>

        @if (_historial.Items.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.NotificationsOff">
                @L["Notif_NoResults"]
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="NotificacionItemDto"
                         Items="_historial.Items"
                         Dense="true"
                         Filterable="false"
                         SortMode="SortMode.Single"
                         RowsPerPage="5"
                         Style="border-radius:12px;overflow:hidden;">
                <Columns>
                    <TemplateColumn Title="@L["Notif_ColSentDate"]" Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2" Style="white-space:nowrap;">
                                @context.Item.FechaEnvio.LocalDateTime.ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.Nombre" Title="@L["Label_Employee"]" />
                    <PropertyColumn Property="x => x.Email" Title="@L["Label_Email"]" />
                    <TemplateColumn Title="@L["Notif_ColDaysWithout"]" Sortable="true">
                        <CellTemplate>
                            @(context.Item.DiasAcumulados >= 999 ? L["Dash_NoDaysWithout"].Value : $"{context.Item.DiasAcumulados} d")
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Notif_ColRefDate"]" Sortable="false">
                        <CellTemplate>@context.Item.FechaReferencia.ToString("dd/MM/yyyy")</CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Label_Status"]" Sortable="true">
                        <CellTemplate>
                            @if (context.Item.Exitoso)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">
                                    @L["Notif_Sent"]
                                </MudChip>
                            }
                            else
                            {
                                <MudTooltip Text="@context.Item.ErrorDetalle">
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">
                                        Error
                                    </MudChip>
                                </MudTooltip>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="NotificacionItemDto" PageSizeOptions="new[] { 5, 10, 20, 50, 100 }" RowsPerPageString="@L["Pager_RowsPerPage"]" />
                </PagerContent>
            </MudDataGrid>
        }
    }

</MudStack>

@code {
    private BreadcrumbItem[] _breadcrumbs => [
        new(L["Nav_Home"].Value, "/"),
        new(L["Nav_Notifications"].Value, null, disabled: true)
    ];

    private HistorialNotificacionesResponse? _historial;
    private bool _isLoading = false;
    private string _errorMessage = string.Empty;

    private List<UserAdminResponse> _usuarios = [];
    private string? _filtroUserId;
    private DateOnly? _filtroDesde;
    private DateOnly? _filtroHasta;
    private bool? _filtroSoloErrores;

    private DateTime? _filtroDesdeDate => _filtroDesde?.ToDateTime(TimeOnly.MinValue);
    private DateTime? _filtroHastaDate => _filtroHasta?.ToDateTime(TimeOnly.MinValue);

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(CargarUsuariosAsync(), BuscarAsync());
    }

    private async Task CargarUsuariosAsync()
    {
        try
        {
            var paged = await UsuariosRepo.GetUsersAsync(pageNumber: 1, pageSize: 200, sortBy: "email", sortDescending: false);
            _usuarios = paged?.Items ?? [];
        }
        catch { /* lista vacía */ }
    }

    private async Task BuscarAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        StateHasChanged();
        try
        {
            _historial = await Repo.GetHistorialAsync(_filtroDesde, _filtroHasta, _filtroUserId, _filtroSoloErrores);
            if (_historial is null)
                _errorMessage = L["Notif_ErrorLoad"];
        }
        catch { _errorMessage = L["Error_Server"]; }
        finally { _isLoading = false; }
    }
}
