@page "/solicitudes-excepcion"
@attribute [Authorize(Roles = Roles.Admin)]
@inject ISolicitudExcepcionAdminRepository Repo

<PageTitle>Solicitudes de excepción - KPG Timesheet</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">
            Solicitudes de excepción
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Autoriza o rechaza solicitudes de registro fuera de la ventana permitida.
        </MudText>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Size="Size.Small" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <MudAlert Severity="Severity.Success" Dense="true" role="status">@_successMessage</MudAlert>
        }

        @if (_solicitudes.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.CheckCircle">
                No hay solicitudes registradas.
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="SolicitudExcepcionAdminResponse"
                         Items="_solicitudes"
                         Dense="true"
                         Filterable="false"
                         SortMode="SortMode.Single"
                         RowsPerPage="25">
                <Columns>
                    <PropertyColumn Property="x => x.SolicitanteEmail" Title="Solicitante" />
                    <TemplateColumn Title="Fecha solicitada" Sortable="true">
                        <CellTemplate>
                            @context.Item.FechaRegistro.ToString("dd/MM/yyyy")
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Antigüedad" Sortable="false">
                        <CellTemplate>
                            @{ var dias = (int)(DateTimeOffset.UtcNow - context.Item.Created).TotalDays; }
                            hace @dias día@(dias == 1 ? "" : "s")
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.Justificacion" Title="Justificación" Sortable="false" />
                    <TemplateColumn Title="Estado" Sortable="false">
                        <CellTemplate>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@GetEstadoColor(context.Item.Estado)">
                                @context.Item.Estado
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Acciones" Sortable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                           Color="Color.Success"
                                           Size="Size.Small"
                                           aria-label="Aprobar solicitud"
                                           Disabled="@(context.Item.Estado != "Pendiente" || _isProcesando)"
                                           OnClick="@(() => ConfirmarAprobarAsync(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           aria-label="Rechazar solicitud"
                                           Disabled="@(context.Item.Estado != "Pendiente" || _isProcesando)"
                                           OnClick="@(() => ConfirmarRechazarAsync(context.Item))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        }
    }

    <MudMessageBox @ref="_msgBox" CancelText="Cancelar">
        <MessageContent>@_msgBoxContent</MessageContent>
        <YesButton>
            <MudButton Color="@_msgBoxColor" Variant="Variant.Filled">Confirmar</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private List<SolicitudExcepcionAdminResponse> _solicitudes = [];
    private bool _isLoading = true;
    private bool _isProcesando;
    private string? _errorMessage;
    private string? _successMessage;
    private MudMessageBox? _msgBox;
    private string _msgBoxContent = string.Empty;
    private Color _msgBoxColor = Color.Primary;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _solicitudes = await Repo.GetAllAsync();
        }
        catch
        {
            _errorMessage = "No fue posible cargar las solicitudes. Intente nuevamente.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ConfirmarAprobarAsync(SolicitudExcepcionAdminResponse item)
    {
        _msgBoxContent = $"¿Aprobar la solicitud de {item.SolicitanteEmail} para el {item.FechaRegistro:dd/MM/yyyy}?";
        _msgBoxColor = Color.Success;
        StateHasChanged();

        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        await ProcesarAsync(item, aprobar: true);
    }

    private async Task ConfirmarRechazarAsync(SolicitudExcepcionAdminResponse item)
    {
        _msgBoxContent = $"¿Rechazar la solicitud de {item.SolicitanteEmail} para el {item.FechaRegistro:dd/MM/yyyy}?";
        _msgBoxColor = Color.Error;
        StateHasChanged();

        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        await ProcesarAsync(item, aprobar: false);
    }

    private async Task ProcesarAsync(SolicitudExcepcionAdminResponse item, bool aprobar)
    {
        _isProcesando = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            var ok = aprobar
                ? await Repo.AprobarAsync(item.Id)
                : await Repo.RechazarAsync(item.Id);

            if (ok)
            {
                var nuevoEstado = aprobar ? "Aprobada" : "Rechazada";
                var idx = _solicitudes.IndexOf(item);
                if (idx >= 0)
                    _solicitudes[idx] = item with { Estado = nuevoEstado };

                _successMessage = aprobar
                    ? $"Solicitud de {item.SolicitanteEmail} aprobada."
                    : $"Solicitud de {item.SolicitanteEmail} rechazada.";
            }
            else
            {
                _errorMessage = "No fue posible procesar la solicitud. Intente nuevamente.";
            }
        }
        catch
        {
            _errorMessage = "Ocurrió un error al procesar la solicitud.";
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private static Color GetEstadoColor(string estado) => estado switch
    {
        "Aprobada" => Color.Success,
        "Rechazada" => Color.Error,
        _ => Color.Warning
    };
}
