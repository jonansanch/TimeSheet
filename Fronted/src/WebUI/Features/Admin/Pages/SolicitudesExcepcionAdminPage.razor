@page "/solicitudes-excepcion"
@attribute [Authorize(Roles = Roles.Admin)]
@inject ISolicitudExcepcionAdminRepository Repo
@inject IStringLocalizer<SharedResource> L
@inject ISnackbar Snackbar

<PageTitle>@L["Exc_Title"] - KPG Timesheet</PageTitle>

<MudStack Spacing="3">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">
            @L["Exc_Title"]
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @L["Exc_Subtitle"]
        </MudText>
    </div>

    @if (_isLoading)
    {
        <KpgTableSkeleton />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
    }
    else
    {
        @if (_solicitudes.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.CheckCircle">
                @L["Exc_NoRequests"]
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="SolicitudExcepcionAdminResponse"
                         Items="_solicitudes"
                         Dense="true"
                         Filterable="false"
                         SortMode="SortMode.Single"
                         RowsPerPage="5">
                <Columns>
                    <PropertyColumn Property="x => x.SolicitanteEmail" Title="@L["Exc_ColEmployee"]" />
                    <TemplateColumn Title="@L["Exc_ColDate"]" Sortable="true">
                        <CellTemplate>
                            @context.Item.FechaRegistro.ToString("dd/MM/yyyy")
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Exc_ColAge"]" Sortable="false">
                        <CellTemplate>
                            @{ var dias = (int)(DateTimeOffset.UtcNow - context.Item.Created).TotalDays; }
                            @(string.Format(dias == 1 ? L["Exc_DayAgo"].Value : L["Exc_DaysAgo"].Value, dias))
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.Justificacion" Title="@L["Exc_ColJustification"]" Sortable="false" />
                    <TemplateColumn Title="@L["Exc_ColStatus"]" Sortable="false">
                        <CellTemplate>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@GetEstadoColor(context.Item.Estado)">
                                @context.Item.Estado
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Label_Actions"]" Sortable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                           Color="Color.Success"
                                           Size="Size.Small"
                                           aria-label="@L["Exc_BtnApprove"]"
                                           Disabled="@(context.Item.Estado != "Pendiente" || _isProcesando)"
                                           OnClick="@(() => ConfirmarAprobarAsync(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           aria-label="@L["Exc_BtnReject"]"
                                           Disabled="@(context.Item.Estado != "Pendiente" || _isProcesando)"
                                           OnClick="@(() => ConfirmarRechazarAsync(context.Item))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="SolicitudExcepcionAdminResponse" PageSizeOptions="new[] { 5, 10, 20, 50, 100 }" RowsPerPageString="@L["Pager_RowsPerPage"]" />
                </PagerContent>
            </MudDataGrid>
        }
    }

    <MudMessageBox @ref="_msgBox" CancelText="@L["Btn_Cancel"]">
        <MessageContent>@_msgBoxContent</MessageContent>
        <YesButton>
            <MudButton Color="@_msgBoxColor" Variant="Variant.Filled">@L["Btn_Confirm"]</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private BreadcrumbItem[] _breadcrumbs => [
        new(L["Nav_Home"].Value, "/"),
        new(L["Nav_Admin"].Value, null, disabled: true),
        new(L["Nav_ExceptionRequests"].Value, null, disabled: true)
    ];

    private List<SolicitudExcepcionAdminResponse> _solicitudes = [];
    private bool _isLoading = true;
    private bool _isProcesando;
    private string? _errorMessage;
    private MudMessageBox? _msgBox;
    private string _msgBoxContent = string.Empty;
    private Color _msgBoxColor = Color.Primary;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _solicitudes = await Repo.GetAllAsync();
        }
        catch
        {
            _errorMessage = L["Exc_ErrorLoad"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ConfirmarAprobarAsync(SolicitudExcepcionAdminResponse item)
    {
        _msgBoxContent = string.Format(L["Exc_ApproveConfirm"], item.SolicitanteEmail, item.FechaRegistro.ToString("dd/MM/yyyy"));
        _msgBoxColor = Color.Success;
        StateHasChanged();

        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        await ProcesarAsync(item, aprobar: true);
    }

    private async Task ConfirmarRechazarAsync(SolicitudExcepcionAdminResponse item)
    {
        _msgBoxContent = string.Format(L["Exc_RejectConfirm"], item.SolicitanteEmail, item.FechaRegistro.ToString("dd/MM/yyyy"));
        _msgBoxColor = Color.Error;
        StateHasChanged();

        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        await ProcesarAsync(item, aprobar: false);
    }

    private async Task ProcesarAsync(SolicitudExcepcionAdminResponse item, bool aprobar)
    {
        _isProcesando = true;

        try
        {
            var ok = aprobar
                ? await Repo.AprobarAsync(item.Id)
                : await Repo.RechazarAsync(item.Id);

            if (ok)
            {
                var nuevoEstado = aprobar ? "Aprobada" : "Rechazada";
                var idx = _solicitudes.IndexOf(item);
                if (idx >= 0)
                    _solicitudes[idx] = item with { Estado = nuevoEstado };

                Snackbar.Add(aprobar ? L["Exc_ApprovedMsg"].Value : L["Exc_RejectedMsg"].Value, Severity.Success);
            }
            else
            {
                Snackbar.Add(L["Exc_ErrorAction"].Value, Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add(L["Exc_ErrorAction"].Value, Severity.Error);
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private static Color GetEstadoColor(string estado) => estado switch
    {
        "Aprobada" => Color.Success,
        "Rechazada" => Color.Error,
        _ => Color.Warning
    };
}
