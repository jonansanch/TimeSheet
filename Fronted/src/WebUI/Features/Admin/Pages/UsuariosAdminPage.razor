@page "/admin/usuarios"
@attribute [Authorize(Roles = Roles.Admin)]
@inject IUserAdminRepository Repo
@inject IDialogService DialogService
@inject IStringLocalizer<SharedResource> L
@inject ISnackbar Snackbar

<PageTitle>@L["Users_Title"] - KPG Timesheet</PageTitle>

<MudStack Spacing="3">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">
                @L["Users_Title"]
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @L["Users_Subtitle"]
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="AbrirCrearAsync">
            @L["Users_NewUser"]
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <KpgTableSkeleton />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
    }
    else
    {
        @if (_usuarios.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.People">
                @L["Users_ErrorLoad"]
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="UserAdminResponse"
                         Items="_usuarios"
                         Dense="true"
                         Filterable="false"
                         SortMode="SortMode.Single"
                         QuickFilter="_quickFilter"
                         RowsPerPage="5">
                <ToolBarContent>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchText"
                                  Placeholder="@($"{L["Label_Email"].Value}...")"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Small"
                                  Immediate="true"
                                  Style="max-width:280px;" />
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.Email" Title="@L["Users_ColEmail"]" />
                    <PropertyColumn Property="x => x.NombreCompleto" Title="@L["Users_ColName"]" />
                    <PropertyColumn Property="x => x.Role" Title="@L["Users_ColRole"]" />
                    <TemplateColumn Title="@L["Users_ColStatus"]" Sortable="true">
                        <CellTemplate>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                                @(context.Item.IsActive ? L["Label_Active"].Value : L["Label_Inactive"].Value)
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Users_ColDeactivated"]" Sortable="true">
                        <CellTemplate>
                            @(context.Item.DeactivatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Label_Actions"]" Sortable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           aria-label="@L["Users_ChangeRole"]"
                                           Disabled="_isProcesando"
                                           OnClick="@(() => AbrirCambiarRolAsync(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.LockReset"
                                           Color="Color.Warning"
                                           Size="Size.Small"
                                           aria-label="@L["Users_ResetPasswordTitle"]"
                                           Disabled="_isProcesando"
                                           OnClick="@(() => AbrirResetPasswordAsync(context.Item))" />
                            @if (context.Item.IsActive)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Block"
                                               Color="Color.Warning"
                                               Size="Size.Small"
                                               aria-label="@L["Btn_Deactivate"]"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ConfirmarDesactivarAsync(context.Item))" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               aria-label="@L["Btn_Activate"]"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ActivarAsync(context.Item))" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           aria-label="@L["Btn_Delete"]"
                                           Disabled="_isProcesando"
                                           OnClick="@(() => ConfirmarEliminarAsync(context.Item))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="UserAdminResponse" PageSizeOptions="new[] { 5, 10, 20, 50, 100 }" RowsPerPageString="@L["Pager_RowsPerPage"]" />
                </PagerContent>
            </MudDataGrid>
        }
    }

    <MudMessageBox @ref="_msgBox" CancelText="@L["Btn_Cancel"]">
        <MessageContent>@_msgBoxContent</MessageContent>
        <YesButton>
            <MudButton Color="@_msgBoxColor" Variant="Variant.Filled">@L["Btn_Confirm"]</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private BreadcrumbItem[] _breadcrumbs => [
        new(L["Nav_Home"].Value, "/"),
        new(L["Nav_Admin"].Value, null, disabled: true),
        new(L["Nav_Users"].Value, null, disabled: true)
    ];

    private List<UserAdminResponse> _usuarios = [];
    private bool _isLoading = true;
    private bool _isProcesando;
    private string? _errorMessage;
    private MudMessageBox? _msgBox;
    private string _msgBoxContent = string.Empty;
    private Color _msgBoxColor = Color.Primary;
    private string _searchText = string.Empty;

    private Func<UserAdminResponse, bool> _quickFilter =>
        u => string.IsNullOrWhiteSpace(_searchText)
            || u.Email.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var page = await Repo.GetUsersAsync(1, 100, "email", false);
            _usuarios = page.Items;
        }
        catch
        {
            _errorMessage = L["Users_ErrorLoad"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AbrirCrearAsync()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<KpgUserDialog>(L["Users_NewTitle"], options);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not CreateUserRequest request)
            return;

        _isProcesando = true;

        try
        {
            var (ok, user, error) = await Repo.CreateAsync(request);
            if (ok && user is not null)
            {
                _usuarios.Add(user);
                _usuarios = _usuarios.OrderBy(u => u.Email).ToList();
                Snackbar.Add(L["Users_SavedOk"].Value, Severity.Success);
            }
            else
            {
                Snackbar.Add(error ?? L["Users_ErrorSave"].Value, Severity.Error);
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private async Task AbrirCambiarRolAsync(UserAdminResponse item)
    {
        var parameters = new DialogParameters<KpgUserRoleDialog>
        {
            { x => x.Email, item.Email },
            { x => x.CurrentRole, item.Role }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<KpgUserRoleDialog>(L["Users_ChangeRole"], parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not ChangeUserRoleRequest request)
            return;

        _isProcesando = true;

        try
        {
            var (ok, user, error) = await Repo.ChangeRoleAsync(item.Id, request);
            if (ok && user is not null)
            {
                ReemplazarUsuario(item, user);
                Snackbar.Add(L["Users_RoleChanged"].Value, Severity.Success);
            }
            else
            {
                Snackbar.Add(error ?? L["Users_ErrorSave"].Value, Severity.Error);
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private async Task ActivarAsync(UserAdminResponse item)
    {
        _isProcesando = true;

        try
        {
            var (ok, user) = await Repo.ActivateAsync(item.Id);
            if (ok && user is not null)
            {
                ReemplazarUsuario(item, user);
                Snackbar.Add(L["Users_SavedOk"].Value, Severity.Success);
            }
            else
            {
                Snackbar.Add(L["Users_ErrorSave"].Value, Severity.Error);
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private async Task ConfirmarDesactivarAsync(UserAdminResponse item)
    {
        _msgBoxContent = string.Format(L["Users_DeactivateConfirm"], item.Email);
        _msgBoxColor = Color.Warning;
        StateHasChanged();

        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        _isProcesando = true;

        try
        {
            var (ok, user) = await Repo.DeactivateAsync(item.Id);
            if (ok && user is not null)
            {
                ReemplazarUsuario(item, user);
                Snackbar.Add(L["Users_SavedOk"].Value, Severity.Success);
            }
            else
            {
                Snackbar.Add(L["Users_ErrorSave"].Value, Severity.Error);
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private async Task ConfirmarEliminarAsync(UserAdminResponse item)
    {
        _msgBoxContent = string.Format(L["Users_DeactivateConfirm"], item.Email);
        _msgBoxColor = Color.Error;
        StateHasChanged();

        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        _isProcesando = true;

        try
        {
            var (ok, result) = await Repo.DeleteAsync(item.Id);
            if (ok && result is not null)
            {
                if (result.WasHardDeleted)
                {
                    _usuarios.Remove(item);
                }
                else
                {
                    ReemplazarUsuario(item, item with { IsActive = false, DeactivatedAt = DateTimeOffset.Now });
                }
                Snackbar.Add(L["Users_SavedOk"].Value, Severity.Success);
            }
            else
            {
                Snackbar.Add(L["Users_ErrorSave"].Value, Severity.Error);
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private async Task AbrirResetPasswordAsync(UserAdminResponse item)
    {
        var parameters = new DialogParameters<KpgUserPasswordDialog>
        {
            { x => x.Email, item.Email }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<KpgUserPasswordDialog>(L["Users_ResetPasswordTitle"], parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not AdminResetPasswordRequest request)
            return;

        _isProcesando = true;

        try
        {
            var (ok, error) = await Repo.AdminResetPasswordAsync(item.Id, request);
            if (ok)
                Snackbar.Add(L["Users_PasswordResetOk"].Value, Severity.Success);
            else
                Snackbar.Add(error ?? L["Users_ErrorSave"].Value, Severity.Error);
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private void ReemplazarUsuario(UserAdminResponse oldItem, UserAdminResponse newItem)
    {
        var idx = _usuarios.IndexOf(oldItem);
        if (idx >= 0)
            _usuarios[idx] = newItem;
    }
}
