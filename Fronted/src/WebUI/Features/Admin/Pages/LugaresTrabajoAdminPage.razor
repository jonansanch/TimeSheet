@page "/admin/parametros/lugares"
@attribute [Authorize(Roles = Roles.Admin)]
@inject ILugarTrabajoRepository LugarRepo
@inject IDialogService DialogService

<PageTitle>Lugares de Trabajo - KPG Timesheet</PageTitle>

<MudStack Spacing="4">
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">Lugares de Trabajo</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Lugares de trabajo disponibles en el sistema.</MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <MudAlert Severity="Severity.Success" Dense="true" role="status">@_success</MudAlert>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_error</MudAlert>
    }

    <MudPaper Elevation="1" Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600;">Lista de Lugares</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="_isProcesando"
                       OnClick="AbrirCrearAsync">
                Nuevo Lugar
            </MudButton>
        </MudStack>

        @if (_isLoading)
        {
            <KpgTableSkeleton />
        }
        else if (_lugares.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.LocationOn">
                No hay lugares de trabajo registrados.
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="LugarTrabajoResponse" Items="_lugares" Dense="true" Filterable="false" SortMode="SortMode.None" RowsPerPage="5">
                <Columns>
                    <PropertyColumn Property="x => x.Nombre" Title="Nombre" />
                    <TemplateColumn Title="Estado" Sortable="false">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.Item.Activo ? Color.Success : Color.Default)">
                                @(context.Item.Activo ? "Activo" : "Inactivo")
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Acciones" Sortable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary" Size="Size.Small"
                                           aria-label="Editar lugar"
                                           Disabled="_isProcesando"
                                           OnClick="@(() => AbrirEditarAsync(context.Item))" />
                            @if (context.Item.Activo)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ToggleOff"
                                               Color="Color.Warning" Size="Size.Small"
                                               aria-label="Desactivar lugar"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ConfirmarToggleAsync(context.Item))" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ToggleOn"
                                               Color="Color.Success" Size="Size.Small"
                                               aria-label="Activar lugar"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ConfirmarToggleAsync(context.Item))" />
                            }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="LugarTrabajoResponse" PageSizeOptions="new[] { 5, 10, 20, 50, 100 }" RowsPerPageString="Mostrar:" />
                </PagerContent>
            </MudDataGrid>
        }
    </MudPaper>

    <MudMessageBox @ref="_msgBox" CancelText="Cancelar">
        <MessageContent>@_msgBoxContent</MessageContent>
        <YesButton>
            <MudButton Color="@_msgBoxColor" Variant="Variant.Filled">Confirmar</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private bool _isLoading = true;
    private bool _isProcesando;
    private List<LugarTrabajoResponse> _lugares = [];
    private string? _error;
    private string? _success;
    private MudMessageBox? _msgBox;
    private string _msgBoxContent = string.Empty;
    private Color  _msgBoxColor   = Color.Primary;

    protected override async Task OnInitializedAsync()
    {
        try { _lugares = await LugarRepo.GetAllAsync(); }
        catch { _error = "No fue posible cargar los lugares de trabajo."; }
        finally { _isLoading = false; }
    }

    private async Task AbrirCrearAsync()
    {
        var opts   = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<KpgLugarTrabajoDialog>("Nuevo Lugar de Trabajo", opts);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not CreateLugarTrabajoRequest req) return;

        _isProcesando = true; _error = null; _success = null;
        try
        {
            var (ok, l, err) = await LugarRepo.CreateAsync(req);
            if (ok && l is not null)
            {
                _lugares.Add(l);
                _lugares  = [.. _lugares.OrderBy(x => x.Nombre)];
                _success  = $"Lugar \"{l.Nombre}\" creado.";
            }
            else _error = err ?? "No fue posible crear el lugar de trabajo.";
        }
        finally { _isProcesando = false; }
    }

    private async Task AbrirEditarAsync(LugarTrabajoResponse item)
    {
        var params_ = new DialogParameters<KpgLugarTrabajoDialog> { { x => x.Lugar, item } };
        var opts    = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<KpgLugarTrabajoDialog>("Editar Lugar de Trabajo", params_, opts);
        var result  = await dialog.Result;
        if (result?.Canceled != false || result.Data is not UpdateLugarTrabajoRequest req) return;

        _isProcesando = true; _error = null; _success = null;
        try
        {
            var (ok, l, err) = await LugarRepo.UpdateAsync(item.Id, req);
            if (ok && l is not null)
            {
                Reemplazar(item, l);
                _lugares = [.. _lugares.OrderBy(x => x.Nombre)];
                _success = $"Lugar actualizado a \"{l.Nombre}\".";
            }
            else _error = err ?? "No fue posible actualizar el lugar de trabajo.";
        }
        finally { _isProcesando = false; }
    }

    private async Task ConfirmarToggleAsync(LugarTrabajoResponse item)
    {
        _msgBoxContent = item.Activo ? $"¿Desactivar \"{item.Nombre}\"?" : $"¿Activar \"{item.Nombre}\"?";
        _msgBoxColor   = item.Activo ? Color.Warning : Color.Success;
        StateHasChanged();
        if (await _msgBox!.ShowAsync() != true) return;

        _isProcesando = true; _error = null; _success = null;
        try
        {
            var (ok, l, err) = await LugarRepo.ToggleActivoAsync(item.Id);
            if (ok && l is not null)
            {
                Reemplazar(item, l);
                _success = l.Activo ? $"\"{l.Nombre}\" activado." : $"\"{l.Nombre}\" desactivado.";
            }
            else _error = err ?? "No fue posible cambiar el estado.";
        }
        finally { _isProcesando = false; }
    }

    private void Reemplazar(LugarTrabajoResponse viejo, LugarTrabajoResponse nuevo)
    {
        var idx = _lugares.IndexOf(viejo);
        if (idx >= 0) _lugares[idx] = nuevo;
    }
}
