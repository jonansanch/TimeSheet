@page "/admin/parametros/modalidades"
@attribute [Authorize(Roles = Roles.Admin)]
@inject IModalidadRepository ModalidadRepo
@inject IDialogService DialogService

<PageTitle>Modalidades - KPG Timesheet</PageTitle>

<MudStack Spacing="4">
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">Modalidades</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Modalidades de trabajo disponibles en el sistema.</MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <MudAlert Severity="Severity.Success" Dense="true" role="status">@_success</MudAlert>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_error</MudAlert>
    }

    <MudPaper Elevation="1" Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600;">Lista de Modalidades</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="_isProcesando"
                       OnClick="AbrirCrearAsync">
                Nueva Modalidad
            </MudButton>
        </MudStack>

        @if (_isLoading)
        {
            <KpgTableSkeleton />
        }
        else if (_modalidades.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Category">
                No hay modalidades registradas.
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="ModalidadResponse" Items="_modalidades" Dense="true" Filterable="false" SortMode="SortMode.None" RowsPerPage="5">
                <Columns>
                    <PropertyColumn Property="x => x.Nombre" Title="Nombre" />
                    <TemplateColumn Title="Estado" Sortable="false">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.Item.Activo ? Color.Success : Color.Default)">
                                @(context.Item.Activo ? "Activa" : "Inactiva")
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Acciones" Sortable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary" Size="Size.Small"
                                           aria-label="Editar modalidad"
                                           Disabled="_isProcesando"
                                           OnClick="@(() => AbrirEditarAsync(context.Item))" />
                            @if (context.Item.Activo)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ToggleOff"
                                               Color="Color.Warning" Size="Size.Small"
                                               aria-label="Desactivar modalidad"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ConfirmarToggleAsync(context.Item))" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ToggleOn"
                                               Color="Color.Success" Size="Size.Small"
                                               aria-label="Activar modalidad"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ConfirmarToggleAsync(context.Item))" />
                            }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="ModalidadResponse" PageSizeOptions="new[] { 5, 10, 20, 50, 100 }" RowsPerPageString="Mostrar:" />
                </PagerContent>
            </MudDataGrid>
        }
    </MudPaper>

    <MudMessageBox @ref="_msgBox" CancelText="Cancelar">
        <MessageContent>@_msgBoxContent</MessageContent>
        <YesButton>
            <MudButton Color="@_msgBoxColor" Variant="Variant.Filled">Confirmar</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private bool _isLoading = true;
    private bool _isProcesando;
    private List<ModalidadResponse> _modalidades = [];
    private string? _error;
    private string? _success;
    private MudMessageBox? _msgBox;
    private string _msgBoxContent = string.Empty;
    private Color  _msgBoxColor   = Color.Primary;

    protected override async Task OnInitializedAsync()
    {
        try { _modalidades = await ModalidadRepo.GetAllAsync(); }
        catch { _error = "No fue posible cargar las modalidades."; }
        finally { _isLoading = false; }
    }

    private async Task AbrirCrearAsync()
    {
        var opts   = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<KpgModalidadDialog>("Nueva Modalidad", opts);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not CreateModalidadRequest req) return;

        _isProcesando = true; _error = null; _success = null;
        try
        {
            var (ok, m, err) = await ModalidadRepo.CreateAsync(req);
            if (ok && m is not null)
            {
                _modalidades.Add(m);
                _modalidades = [.. _modalidades.OrderBy(x => x.Nombre)];
                _success = $"Modalidad \"{m.Nombre}\" creada.";
            }
            else _error = err ?? "No fue posible crear la modalidad.";
        }
        finally { _isProcesando = false; }
    }

    private async Task AbrirEditarAsync(ModalidadResponse item)
    {
        var params_ = new DialogParameters<KpgModalidadDialog> { { x => x.Modalidad, item } };
        var opts    = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<KpgModalidadDialog>("Editar Modalidad", params_, opts);
        var result  = await dialog.Result;
        if (result?.Canceled != false || result.Data is not UpdateModalidadRequest req) return;

        _isProcesando = true; _error = null; _success = null;
        try
        {
            var (ok, m, err) = await ModalidadRepo.UpdateAsync(item.Id, req);
            if (ok && m is not null)
            {
                Reemplazar(item, m);
                _modalidades = [.. _modalidades.OrderBy(x => x.Nombre)];
                _success = $"Modalidad actualizada a \"{m.Nombre}\".";
            }
            else _error = err ?? "No fue posible actualizar la modalidad.";
        }
        finally { _isProcesando = false; }
    }

    private async Task ConfirmarToggleAsync(ModalidadResponse item)
    {
        _msgBoxContent = item.Activo ? $"¿Desactivar \"{item.Nombre}\"?" : $"¿Activar \"{item.Nombre}\"?";
        _msgBoxColor   = item.Activo ? Color.Warning : Color.Success;
        StateHasChanged();
        if (await _msgBox!.ShowAsync() != true) return;

        _isProcesando = true; _error = null; _success = null;
        try
        {
            var (ok, m, err) = await ModalidadRepo.ToggleActivaAsync(item.Id);
            if (ok && m is not null)
            {
                Reemplazar(item, m);
                _success = m.Activo ? $"\"{m.Nombre}\" activada." : $"\"{m.Nombre}\" desactivada.";
            }
            else _error = err ?? "No fue posible cambiar el estado.";
        }
        finally { _isProcesando = false; }
    }

    private void Reemplazar(ModalidadResponse viejo, ModalidadResponse nuevo)
    {
        var idx = _modalidades.IndexOf(viejo);
        if (idx >= 0) _modalidades[idx] = nuevo;
    }
}
