@page "/admin/bitacora"
@attribute [Authorize(Roles = Roles.Admin)]
@inject IBitacoraAdminRepository Repo
@inject IUserAdminRepository UsuariosRepo
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L
@inject ISnackbar Snackbar

<PageTitle>@L["Bit_TitleAdmin"] - KPG Timesheet</PageTitle>

<MudStack Spacing="4">

    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">@L["Bit_TitleAdmin"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Bit_Subtitle2"]</MudText>
    </div>

    <MudPaper Elevation="2" Class="pa-4" Style="border-radius:12px;">
        <MudGrid Spacing="2">

            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="@L["Bit_LabelFrom"]"
                               Date="_filtroDesdeDate"
                               DateChanged="d => _filtroDesde = d.HasValue ? DateOnly.FromDateTime(d.Value) : null"
                               MaxDate="DateTime.Today"
                               PickerVariant="PickerVariant.Dialog"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               aria-label="@L["Bit_LabelFrom"]" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="@L["Bit_LabelTo"]"
                               Date="_filtroHastaDate"
                               DateChanged="d => _filtroHasta = d.HasValue ? DateOnly.FromDateTime(d.Value) : null"
                               MaxDate="DateTime.Today"
                               PickerVariant="PickerVariant.Dialog"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               aria-label="@L["Bit_LabelTo"]" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           Label="@L["Label_User"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true"
                           Value="_filtroActorId"
                           ValueChanged="v => _filtroActorId = v"
                           aria-label="@L["Label_User"]">
                    @foreach (var u in _usuarios)
                    {
                        <MudSelectItem Value="@u.Id">@(u.NombreCompleto ?? u.Email)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           Label="@L["Label_FilterEventType"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true"
                           Value="_filtroTipoEvento"
                           ValueChanged="v => _filtroTipoEvento = v"
                           aria-label="@L["Label_FilterEventType"]">
                    @foreach (var tipo in _tiposEvento)
                    {
                        <MudSelectItem Value="@tipo">@tipo</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="BuscarAsync"
                               Disabled="_isLoading">
                        @L["Btn_Search"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="ExportarExcelAsync"
                               Disabled="@(_bitacora is null || _bitacora.Items.Count == 0 || _isExporting)"
                               aria-label="@L["Btn_ExportExcel"]">
                        @if (_isExporting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Excel
                    </MudButton>
                </MudStack>
            </MudItem>

        </MudGrid>
    </MudPaper>

    @if (_isLoading)
    {
        <KpgTableSkeleton Rows="8" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
    }
    else if (_bitacora is not null)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudChip T="string" Color="Color.Primary" Size="Size.Small">
                @_bitacora.Total @(_bitacora.Total == 1 ? L["Bit_TotalEvents"].Value : L["Bit_TotalEventsPlural"].Value)
            </MudChip>
        </MudStack>

        @if (_bitacora.Items.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.SearchOff">
                @L["Bit_NoEvents"]
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="BitacoraItemDto"
                         Items="_bitacora.Items"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         Filterable="false"
                         SortMode="SortMode.Single"
                         RowsPerPage="5"
                         Style="border-radius:12px;overflow:hidden;">
                <Columns>
                    <TemplateColumn Title="@L["Bit_ColDateTime"]" Sortable="true" CellStyle="white-space:nowrap;">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">
                                @context.Item.Timestamp.LocalDateTime.ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Bit_ColEventType"]" Sortable="true">
                        <CellTemplate>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@GetTipoColor(context.Item.TipoEvento)"
                                     Variant="Variant.Filled"
                                     Style="margin:0;">
                                @context.Item.TipoEvento
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Bit_ColActor"]" Sortable="false">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">
                                @(context.Item.ActorNombre ?? context.Item.ActorEmail ?? context.Item.ActorId)
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.EntidadAfectada" Title="@L["Bit_ColEntity"]" />
                    <TemplateColumn Title="@L["Bit_ColEntityId"]" Sortable="false">
                        <CellTemplate>
                            @if (!string.IsNullOrWhiteSpace(context.Item.EntidadId))
                            {
                                <MudTooltip Text="@context.Item.EntidadId" Placement="Placement.Left">
                                    <MudText Typo="Typo.caption"
                                             Style="cursor:default;font-family:monospace;max-width:100px;overflow:hidden;text-overflow:ellipsis;display:block;white-space:nowrap;">
                                        @(context.Item.EntidadId.Length > 8
                                            ? context.Item.EntidadId[..8] + "…"
                                            : context.Item.EntidadId)
                                    </MudText>
                                </MudTooltip>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Bit_ColMetadata"]" Sortable="false">
                        <CellTemplate>
                            @if (!string.IsNullOrWhiteSpace(context.Item.MetadataJson))
                            {
                                <MudTooltip Text="@context.Item.MetadataJson" Placement="Placement.Left">
                                    <MudText Typo="Typo.caption"
                                             Style="cursor:pointer;max-width:140px;overflow:hidden;text-overflow:ellipsis;display:block;white-space:nowrap;">
                                        @(context.Item.MetadataJson.Length > 40
                                            ? context.Item.MetadataJson[..40] + "…"
                                            : context.Item.MetadataJson)
                                    </MudText>
                                </MudTooltip>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="BitacoraItemDto" PageSizeOptions="new[] { 5, 10, 20, 50, 100 }" RowsPerPageString="@L["Pager_RowsPerPage"]" />
                </PagerContent>
            </MudDataGrid>
        }
    }

</MudStack>

@code {
    private BreadcrumbItem[] _breadcrumbs => [
        new(L["Nav_Home"].Value, "/"),
        new(L["Nav_Admin"].Value, null, disabled: true),
        new(L["Nav_AdminBitacora"].Value, null, disabled: true)
    ];

    private BitacoraResponse? _bitacora;
    private bool _isLoading;
    private string _errorMessage = string.Empty;
    private bool _isExporting;

    private List<UserAdminResponse> _usuarios = [];
    private string? _filtroActorId;
    private DateOnly? _filtroDesde;
    private DateOnly? _filtroHasta;
    private string? _filtroTipoEvento;

    private DateTime? _filtroDesdeDate => _filtroDesde?.ToDateTime(TimeOnly.MinValue);
    private DateTime? _filtroHastaDate => _filtroHasta?.ToDateTime(TimeOnly.MinValue);

    private static readonly List<string> _tiposEvento =
    [
        "LoginExitoso", "AltaUsuario", "BajaUsuario", "ReactivacionUsuario",
        "EliminacionUsuario", "CambioRol", "AprobacionExcepcion", "RechazoExcepcion",
        "ModificacionDescripcion", "EliminacionRegistro", "NotificacionEnviada"
    ];

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(CargarUsuariosAsync(), BuscarAsync());
    }

    private async Task CargarUsuariosAsync()
    {
        try
        {
            var paged = await UsuariosRepo.GetUsersAsync(pageNumber: 1, pageSize: 200, sortBy: "email", sortDescending: false);
            _usuarios = paged?.Items ?? [];
        }
        catch { /* lista vacía */ }
    }

    private async Task BuscarAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        StateHasChanged();
        try
        {
            _bitacora = await Repo.GetBitacoraAsync(_filtroDesde, _filtroHasta, _filtroActorId, _filtroTipoEvento);
            if (_bitacora is null)
                _errorMessage = L["Bit_ErrorLoad"];
        }
        catch { _errorMessage = L["Error_Server"]; }
        finally { _isLoading = false; }
    }

    private async Task ExportarExcelAsync()
    {
        _isExporting = true;
        StateHasChanged();
        try
        {
            var result = await Repo.ExportarExcelAsync(_filtroDesde, _filtroHasta, _filtroActorId, _filtroTipoEvento);
            if (result is null)
            {
                Snackbar.Add(L["Bit_ErrorLoad"].Value, Severity.Error);
                return;
            }
            var (bytes, contentType, fileName) = result.Value;
            await JS.InvokeVoidAsync("downloadFile", fileName, contentType, Convert.ToBase64String(bytes));
        }
        catch { Snackbar.Add(L["Error_Server"].Value, Severity.Error); }
        finally { _isExporting = false; }
    }

    private static Color GetTipoColor(string tipo) => tipo switch
    {
        "LoginExitoso"                         => Color.Success,
        "AltaUsuario" or "ReactivacionUsuario" => Color.Info,
        "BajaUsuario" or "EliminacionUsuario"  => Color.Error,
        "CambioRol"                            => Color.Warning,
        _                                      => Color.Default
    };
}
