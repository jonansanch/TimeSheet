@page "/admin/clientes"
@attribute [Authorize(Roles = Roles.Admin)]
@inject IClienteRepository Repo
@inject IDialogService DialogService
@inject IStringLocalizer<SharedResource> L
@inject ISnackbar Snackbar

<PageTitle>@L["Clients_Title"] - KPG Timesheet</PageTitle>

<MudStack Spacing="3">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">
                @L["Clients_Title"]
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @L["Clients_Subtitle"]
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="_isProcesando"
                   OnClick="AbrirCrearAsync">
            @L["Clients_NewClient"]
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <KpgTableSkeleton />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
    }
    else
    {
        @if (_clientes.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Business">
                @L["Clients_ErrorLoad"]
            </MudAlert>
        }
        else
        {
            <MudDataGrid T="ClienteResponse"
                         Items="_clientes"
                         Dense="true"
                         Filterable="false"
                         SortMode="SortMode.Single"
                         QuickFilter="_quickFilter"
                         RowsPerPage="5">
                <ToolBarContent>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchText"
                                  Placeholder="@($"{L["Label_Name"].Value}...")"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Small"
                                  Immediate="true"
                                  Style="max-width:280px;" />
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.Nombre" Title="@L["Clients_ColClient"]" />
                    <TemplateColumn Title="@L["Label_Status"]" Sortable="true">
                        <CellTemplate>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@(context.Item.Activo ? Color.Success : Color.Default)">
                                @(context.Item.Activo ? L["Label_Active"].Value : L["Label_Inactive"].Value)
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@L["Label_Actions"]" Sortable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           aria-label="@L["Btn_Edit"]"
                                           Disabled="_isProcesando"
                                           OnClick="@(() => AbrirEditarAsync(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.FolderOpen"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           aria-label="@L["Label_Projects"]"
                                           Disabled="_isProcesando"
                                           OnClick="@(() => AbrirProyectosAsync(context.Item))" />
                            @if (context.Item.Activo)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ToggleOff"
                                               Color="Color.Warning"
                                               Size="Size.Small"
                                               aria-label="@L["Btn_Deactivate"]"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ConfirmarToggleAsync(context.Item))" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ToggleOn"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               aria-label="@L["Btn_Activate"]"
                                               Disabled="_isProcesando"
                                               OnClick="@(() => ConfirmarToggleAsync(context.Item))" />
                            }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="ClienteResponse" PageSizeOptions="new[] { 5, 10, 20, 50, 100 }" RowsPerPageString="@L["Pager_RowsPerPage"]" />
                </PagerContent>
            </MudDataGrid>
        }
    }

    <MudMessageBox @ref="_msgBox" CancelText="@L["Btn_Cancel"]">
        <MessageContent>@_msgBoxContent</MessageContent>
        <YesButton>
            <MudButton Color="@_msgBoxColor" Variant="Variant.Filled">@L["Btn_Confirm"]</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private BreadcrumbItem[] _breadcrumbs => [
        new(L["Nav_Home"].Value, "/"),
        new(L["Nav_Admin"].Value, null, disabled: true),
        new(L["Nav_ClientsProjects"].Value, null, disabled: true)
    ];

    private List<ClienteResponse> _clientes = [];
    private bool _isLoading = true;
    private bool _isProcesando;
    private string? _errorMessage;
    private MudMessageBox? _msgBox;
    private string _msgBoxContent = string.Empty;
    private Color _msgBoxColor = Color.Primary;
    private string _searchText = string.Empty;

    private Func<ClienteResponse, bool> _quickFilter =>
        c => string.IsNullOrWhiteSpace(_searchText)
            || c.Nombre.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync() => await CargarAsync();

    private async Task CargarAsync()
    {
        _isLoading = true; _errorMessage = null;
        try { _clientes = await Repo.GetAllAsync(); }
        catch { _errorMessage = L["Clients_ErrorLoad"]; }
        finally { _isLoading = false; }
    }

    private async Task AbrirCrearAsync()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<KpgClienteDialog>(L["Clients_NewClientTitle"], options);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not CreateClienteRequest request) return;

        _isProcesando = true;
        try
        {
            var (ok, cliente, error) = await Repo.CreateAsync(request);
            if (ok && cliente is not null)
            {
                _clientes.Add(cliente);
                _clientes = [.. _clientes.OrderBy(c => c.Nombre)];
                Snackbar.Add(L["Clients_SavedOk"].Value, Severity.Success);
            }
            else Snackbar.Add(error ?? L["Clients_ErrorSave"].Value, Severity.Error);
        }
        finally { _isProcesando = false; }
    }

    private async Task AbrirEditarAsync(ClienteResponse item)
    {
        var parameters = new DialogParameters<KpgClienteDialog> { { x => x.Cliente, item } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<KpgClienteDialog>(L["Clients_EditClientTitle"], parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not UpdateClienteRequest request) return;

        _isProcesando = true;
        try
        {
            var (ok, cliente, error) = await Repo.UpdateAsync(item.Id, request);
            if (ok && cliente is not null)
            {
                Reemplazar(item, cliente);
                _clientes = [.. _clientes.OrderBy(c => c.Nombre)];
                Snackbar.Add(L["Clients_SavedOk"].Value, Severity.Success);
            }
            else Snackbar.Add(error ?? L["Clients_ErrorSave"].Value, Severity.Error);
        }
        finally { _isProcesando = false; }
    }

    private async Task AbrirProyectosAsync(ClienteResponse item)
    {
        var parameters = new DialogParameters<KpgProyectosClienteDialog> { { x => x.Cliente, item } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        await DialogService.ShowAsync<KpgProyectosClienteDialog>($"{L["Label_Projects"]} — {item.Nombre}", parameters, options);
    }

    private async Task ConfirmarToggleAsync(ClienteResponse item)
    {
        _msgBoxContent = item.Activo
            ? string.Format(L["Resources_DeactivateConfirm"], item.Nombre)
            : string.Format(L["Users_ActivateConfirm"], item.Nombre);
        _msgBoxColor = item.Activo ? Color.Warning : Color.Success;
        StateHasChanged();
        if (await _msgBox!.ShowAsync() != true) return;

        _isProcesando = true;
        try
        {
            var (ok, cliente, error) = await Repo.ToggleActivoAsync(item.Id);
            if (ok && cliente is not null)
            {
                Reemplazar(item, cliente);
                Snackbar.Add(L["Clients_SavedOk"].Value, Severity.Success);
            }
            else Snackbar.Add(error ?? L["Clients_ErrorSave"].Value, Severity.Error);
        }
        finally { _isProcesando = false; }
    }

    private void Reemplazar(ClienteResponse viejo, ClienteResponse nuevo)
    {
        var idx = _clientes.IndexOf(viejo);
        if (idx >= 0) _clientes[idx] = nuevo;
    }
}
