@page "/admin/parametros/configuracion"
@attribute [Authorize(Roles = Roles.Admin)]
@inject IParametroSistemaRepository SistemaRepo
@inject IStringLocalizer<SharedResource> L
@inject ISnackbar Snackbar

<PageTitle>@L["Nav_GeneralConfig"] - KPG Timesheet</PageTitle>

<MudStack Spacing="4">
    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0" />
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">@L["Nav_GeneralConfig"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Params_Subtitle"]</MudText>
    </div>

    @if (_isLoading)
    {
        <KpgTableSkeleton />
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-4">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudNumericField T="int"
                                     Label="@L["Params_RetroWindow"]"
                                     Variant="Variant.Outlined"
                                     @bind-Value="_ventana"
                                     Min="1"
                                     Max="30"
                                     HelperText="@L["Params_RetroWindowDesc"]" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField T="int"
                                     Label="@L["Params_NotifThreshold"]"
                                     Variant="Variant.Outlined"
                                     @bind-Value="_umbral"
                                     Min="1"
                                     Max="30"
                                     HelperText="@L["Params_NotifThresholdDesc"]" />
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_isSaving"
                               OnClick="GuardarConfigAsync"
                               StartIcon="@Icons.Material.Filled.Save">
                        @(_isSaving ? L["Loading"].Value : L["Btn_Save"].Value)
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
</MudStack>

@code {
    private BreadcrumbItem[] _breadcrumbs => [
        new(L["Nav_Home"].Value, "/"),
        new(L["Nav_Admin"].Value, null, disabled: true),
        new(L["Nav_Params"].Value, null, disabled: true),
        new(L["Nav_GeneralConfig"].Value, null, disabled: true)
    ];

    private bool _isLoading = true;
    private bool _isSaving;
    private int  _ventana = 3;
    private int  _umbral  = 3;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var vTask = SistemaRepo.GetVentanaRetroactividadAsync();
            var uTask = SistemaRepo.GetUmbralNotificacionAsync();
            await Task.WhenAll(vTask, uTask);
            _ventana = await vTask;
            _umbral  = await uTask;
        }
        catch { Snackbar.Add(L["Params_ErrorLoad"].Value, Severity.Error); }
        finally { _isLoading = false; }
    }

    private async Task GuardarConfigAsync()
    {
        _isSaving = true;
        try
        {
            var (okV, errV) = await SistemaRepo.UpdateVentanaRetroactividadAsync(_ventana);
            var (okU, errU) = await SistemaRepo.UpdateUmbralNotificacionAsync(_umbral);
            if (!okV || !okU)
                Snackbar.Add(errV ?? errU ?? L["Params_ErrorSave"].Value, Severity.Error);
            else
                Snackbar.Add(L["Params_SavedOk"].Value, Severity.Success);
        }
        finally { _isSaving = false; }
    }
}
