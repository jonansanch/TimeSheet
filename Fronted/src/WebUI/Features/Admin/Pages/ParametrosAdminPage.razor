@page "/admin/parametros/configuracion"
@attribute [Authorize(Roles = Roles.Admin)]
@inject IParametroSistemaRepository SistemaRepo

<PageTitle>Configuración General - KPG Timesheet</PageTitle>

<MudStack Spacing="4">
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">Configuración General</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Parámetros globales del sistema.</MudText>
    </div>

    @if (_isLoading)
    {
        <KpgTableSkeleton />
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-4">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudNumericField T="int"
                                     Label="Ventana retroactividad (días)"
                                     Variant="Variant.Outlined"
                                     @bind-Value="_ventana"
                                     Min="1"
                                     Max="30"
                                     HelperText="Días hábiles permitidos para registrar en el pasado (1-30)." />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField T="int"
                                     Label="Umbral notificaciones (días)"
                                     Variant="Variant.Outlined"
                                     @bind-Value="_umbral"
                                     Min="1"
                                     Max="30"
                                     HelperText="Días sin registrar para enviar notificación (1-30)." />
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_isSaving"
                               OnClick="GuardarConfigAsync"
                               StartIcon="@Icons.Material.Filled.Save">
                        @(_isSaving ? "Guardando..." : "Guardar Configuración")
                    </MudButton>
                </MudItem>
            </MudGrid>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2" aria-live="polite">@_error</MudAlert>
            }
            @if (!string.IsNullOrWhiteSpace(_success))
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2" role="status">@_success</MudAlert>
            }
        </MudPaper>
    }
</MudStack>

@code {
    private bool _isLoading = true;
    private bool _isSaving;
    private int  _ventana = 3;
    private int  _umbral  = 3;
    private string? _error;
    private string? _success;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var vTask = SistemaRepo.GetVentanaRetroactividadAsync();
            var uTask = SistemaRepo.GetUmbralNotificacionAsync();
            await Task.WhenAll(vTask, uTask);
            _ventana = await vTask;
            _umbral  = await uTask;
        }
        catch { _error = "No fue posible cargar la configuración."; }
        finally { _isLoading = false; }
    }

    private async Task GuardarConfigAsync()
    {
        _isSaving = true;
        _error    = null;
        _success  = null;
        try
        {
            var (okV, errV) = await SistemaRepo.UpdateVentanaRetroactividadAsync(_ventana);
            var (okU, errU) = await SistemaRepo.UpdateUmbralNotificacionAsync(_umbral);
            if (!okV || !okU)
                _error = errV ?? errU ?? "No fue posible guardar la configuración.";
            else
                _success = "Configuración guardada correctamente.";
        }
        finally { _isSaving = false; }
    }
}
