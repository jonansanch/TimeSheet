@inject IClienteRepository Repo
@inject IDialogService DialogService
@inject IStringLocalizer<SharedResource> L

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Label_Projects"] — @Cliente.Nombre</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @if (!string.IsNullOrWhiteSpace(_successMessage))
            {
                <MudAlert Severity="Severity.Success" Dense="true" role="status">@_successMessage</MudAlert>
            }
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
            }

            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Size="Size.Small" />
            }
            else if (_proyectos.Count == 0)
            {
                <MudAlert Severity="Severity.Info">@L["Proj_NoProjects"]</MudAlert>
            }
            else
            {
                <MudList T="ProyectoResponse" Dense="true">
                    @foreach (var proyecto in _proyectos)
                    {
                        <MudListItem>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText>@proyecto.Nombre</MudText>
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(proyecto.Activo ? Color.Success : Color.Default)">
                                        @(proyecto.Activo ? L["Label_Active"].Value : L["Label_Inactive"].Value)
                                    </MudChip>
                                </MudStack>
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   aria-label="@L["Btn_Edit"]"
                                                   Disabled="_isProcesando"
                                                   OnClick="@(() => AbrirEditarProyectoAsync(proyecto))" />
                                    @if (proyecto.Activo)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.ToggleOff"
                                                       Color="Color.Warning"
                                                       Size="Size.Small"
                                                       aria-label="@L["Btn_Deactivate"]"
                                                       Disabled="_isProcesando"
                                                       OnClick="@(() => ConfirmarToggleProyectoAsync(proyecto))" />
                                    }
                                    else
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.ToggleOn"
                                                       Color="Color.Success"
                                                       Size="Size.Small"
                                                       aria-label="@L["Btn_Activate"]"
                                                       Disabled="_isProcesando"
                                                       OnClick="@(() => ConfirmarToggleProyectoAsync(proyecto))" />
                                    }
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }

            <MudMessageBox @ref="_msgBox" CancelText="@L["Btn_Cancel"]">
                <MessageContent>@_msgBoxContent</MessageContent>
                <YesButton>
                    <MudButton Color="@_msgBoxColor" Variant="Variant.Filled">@L["Btn_Confirm"]</MudButton>
                </YesButton>
            </MudMessageBox>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary"
                   Disabled="_isProcesando"
                   OnClick="AbrirCrearProyectoAsync">
            @L["Proj_NewProject"]
        </MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" OnClick="Cerrar">@L["Btn_Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ClienteResponse Cliente { get; set; } = default!;

    private List<ProyectoResponse> _proyectos = [];
    private bool _isLoading = true;
    private bool _isProcesando;
    private string? _errorMessage;
    private string? _successMessage;
    private MudMessageBox? _msgBox;
    private string _msgBoxContent = string.Empty;
    private Color _msgBoxColor = Color.Primary;

    protected override async Task OnInitializedAsync()
    {
        await CargarProyectosAsync();
    }

    private async Task CargarProyectosAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            _proyectos = await Repo.GetProyectosAsync(Cliente.Id);
        }
        catch
        {
            _errorMessage = L["Proj_ErrorLoad"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AbrirCrearProyectoAsync()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<KpgProyectoDialog>(L["Proj_NewProject"], options);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not CreateProyectoRequest request)
            return;

        _isProcesando = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            var (ok, proyecto, error) = await Repo.CreateProyectoAsync(Cliente.Id, request);
            if (ok && proyecto is not null)
            {
                _proyectos.Add(proyecto);
                _proyectos = [.. _proyectos.OrderBy(p => p.Nombre)];
                _successMessage = L["Proj_SavedOk"];
            }
            else
            {
                _errorMessage = error ?? L["Proj_ErrorSave"];
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private async Task AbrirEditarProyectoAsync(ProyectoResponse item)
    {
        var parameters = new DialogParameters<KpgProyectoDialog> { { x => x.Proyecto, item } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<KpgProyectoDialog>(L["Proj_EditProject"], parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not UpdateProyectoRequest request)
            return;

        _isProcesando = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            var (ok, proyecto, error) = await Repo.UpdateProyectoAsync(item.Id, request);
            if (ok && proyecto is not null)
            {
                ReemplazarProyecto(item, proyecto);
                _proyectos = [.. _proyectos.OrderBy(p => p.Nombre)];
                _successMessage = L["Proj_SavedOk"];
            }
            else
            {
                _errorMessage = error ?? L["Proj_ErrorSave"];
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private async Task ConfirmarToggleProyectoAsync(ProyectoResponse item)
    {
        _msgBoxContent = item.Activo
            ? string.Format(L["Proj_DeactivateConfirm"], item.Nombre)
            : string.Format(L["Proj_ActivateConfirm"], item.Nombre);
        _msgBoxColor = item.Activo ? Color.Warning : Color.Success;
        StateHasChanged();

        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        _isProcesando = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            var (ok, proyecto, error) = await Repo.ToggleProyectoActivoAsync(item.Id);
            if (ok && proyecto is not null)
            {
                ReemplazarProyecto(item, proyecto);
                _successMessage = L["Proj_SavedOk"];
            }
            else
            {
                _errorMessage = error ?? L["Proj_ErrorSave"];
            }
        }
        finally
        {
            _isProcesando = false;
        }
    }

    private void ReemplazarProyecto(ProyectoResponse oldItem, ProyectoResponse newItem)
    {
        var idx = _proyectos.IndexOf(oldItem);
        if (idx >= 0)
            _proyectos[idx] = newItem;
    }

    private void Cerrar() => MudDialog.Close();
}
