@inject IStringLocalizer<SharedResource> L

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Warning" />
            <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Users_ResetPasswordTitle"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                @string.Format(L["Users_ResetPasswordMsg"].Value, Email)
            </MudText>

            <MudTextField @ref="_passwordField"
                          T="string"
                          Label="@L["Label_NewPassword"]"
                          Variant="Variant.Outlined"
                          @bind-Value="_password"
                          Required="true"
                          RequiredError="@L["Val_PasswordRequired"]"
                          InputType="InputType.Password"
                          autocomplete="new-password"
                          HelperText="@L["Users_PasswordHint"]"
                          aria-label="@L["Label_NewPassword"]" />

            <MudTextField T="string"
                          Label="@L["Label_ConfirmPassword"]"
                          Variant="Variant.Outlined"
                          @bind-Value="_confirm"
                          Required="true"
                          InputType="InputType.Password"
                          autocomplete="new-password"
                          Error="@(_confirm.Length > 0 && _confirm != _password)"
                          ErrorText="@L["Val_PasswordMismatch"]"
                          aria-label="@L["Label_ConfirmPassword"]" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">@L["Btn_Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   Disabled="@(!EsValido)"
                   OnClick="Submit">
            @L["Users_ResetPasswordBtn"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Email { get; set; } = string.Empty;

    private MudTextField<string> _passwordField = default!;
    private string _password = string.Empty;
    private string _confirm = string.Empty;

    private bool EsValido =>
        PasswordCumplePolitica(_password) && _password == _confirm;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await _passwordField.FocusAsync();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() =>
        MudDialog.Close(DialogResult.Ok(new AdminResetPasswordRequest(_password)));

    private static bool PasswordCumplePolitica(string password) =>
        password.Length >= 6
        && password.Any(char.IsUpper)
        && password.Any(char.IsLower)
        && password.Any(char.IsDigit)
        && password.Any(ch => !char.IsLetterOrDigit(ch));
}
