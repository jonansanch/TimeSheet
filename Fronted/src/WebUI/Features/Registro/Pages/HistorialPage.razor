@page "/mis-registros"
@attribute [Authorize(Roles = $"{Roles.Empleado},{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")]
@inject IRegistroHorasRepository RegistroHorasRepository
@inject NavigationManager Navigation

<PageTitle>Mis Registros - KPG Timesheet</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">
            Mis Registros
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Historial de horas reportadas.
        </MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <MudAlert Severity="Severity.Success" Dense="true" role="status">@_successMessage</MudAlert>
    }

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Size="Size.Small" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
    }
    else if (_registros.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.EventBusy">
            <MudText Typo="Typo.body1">Aún no tienes registros.</MudText>
            <MudText Typo="Typo.body2" Class="mb-2">Empieza registrando las horas de hoy.</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="@(() => Navigation.NavigateTo("/registro"))">
                Registrar horas
            </MudButton>
        </MudAlert>
    }
    else
    {
        <MudDataGrid T="HistorialRegistroResponse"
                     Items="_registros"
                     Dense="true"
                     Filterable="false"
                     SortMode="SortMode.Single"
                     RowsPerPage="25">
            <Columns>
                <PropertyColumn Property="x => x.FechaRegistro"
                                Title="Fecha"
                                Sortable="true"
                                InitialDirection="SortDirection.Descending">
                    <CellTemplate>
                        @context.Item.FechaRegistro.ToString("dd/MM/yyyy")
                    </CellTemplate>
                </PropertyColumn>
                <TemplateColumn Title="Turno" Sortable="false">
                    <CellTemplate>
                        @context.Item.Turno
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Horario" Sortable="false">
                    <CellTemplate>
                        @context.Item.HoraEntrada.ToString(@"HH\:mm") – @context.Item.HoraSalida.ToString(@"HH\:mm")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Cliente" Title="Cliente" />
                <PropertyColumn Property="x => x.Proyecto" Title="Proyecto" />
                <PropertyColumn Property="x => x.Modalidad" Title="Modalidad" Sortable="false" />
                <PropertyColumn Property="x => x.Descripcion" Title="Descripción" Sortable="false" />
                <TemplateColumn Title="" Sortable="false">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       aria-label="Eliminar registro"
                                       Disabled="_isDeleting"
                                       OnClick="@(() => ConfirmarEliminarAsync(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }

    <MudMessageBox @ref="_msgBox"
                   Title="Eliminar registro"
                   CancelText="Cancelar">
        <MessageContent>
            ¿Eliminar el registro del
            <b>@_pendiente?.FechaRegistro.ToString("dd/MM/yyyy")</b>
            · Turno <b>@_pendiente?.Turno</b>?
            Esta acción no se puede deshacer.
        </MessageContent>
        <YesButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled">Eliminar</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private List<HistorialRegistroResponse> _registros = [];
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _successMessage;
    private bool _isDeleting;
    private HistorialRegistroResponse? _pendiente;
    private MudMessageBox? _msgBox;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _registros = await RegistroHorasRepository.GetHistorialAsync();
        }
        catch
        {
            _errorMessage = "No fue posible cargar el historial. Intente nuevamente.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ConfirmarEliminarAsync(HistorialRegistroResponse item)
    {
        _pendiente = item;
        StateHasChanged();
        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed == true)
            await EliminarAsync(item);
        _pendiente = null;
    }

    private async Task EliminarAsync(HistorialRegistroResponse item)
    {
        _isDeleting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var success = await RegistroHorasRepository.DeleteAsync(item.Id);
            if (success)
            {
                _registros.Remove(item);
                _successMessage = $"Registro del {item.FechaRegistro:dd/MM/yyyy} · Turno {item.Turno} eliminado.";
            }
            else
            {
                _errorMessage = "No fue posible eliminar el registro. Intente nuevamente.";
            }
        }
        catch
        {
            _errorMessage = "Ocurrió un error al eliminar el registro.";
        }
        finally
        {
            _isDeleting = false;
        }
    }
}
