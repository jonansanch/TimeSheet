@page "/mis-registros"
@attribute [Authorize(Roles = $"{Roles.Empleado},{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")]
@inject IRegistroHorasRepository RegistroHorasRepository
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject CurrentUserService CurrentUserService

<PageTitle>Mis Registros - KPG Timesheet</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">
            Mis Registros
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Historial de horas reportadas.
        </MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <MudAlert Severity="Severity.Success" Dense="true" role="status">@_successMessage</MudAlert>
    }

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Size="Size.Small" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
    }
    else if (_registros.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.EventBusy">
            <MudText Typo="Typo.body1">Aún no tienes registros.</MudText>
            <MudText Typo="Typo.body2" Class="mb-2">Empieza registrando las horas de hoy.</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="@(() => Navigation.NavigateTo("/registro"))">
                Registrar horas
            </MudButton>
        </MudAlert>
    }
    else
    {
        <MudDataGrid T="HistorialRegistroResponse"
                     Items="_registros"
                     Dense="true"
                     Filterable="false"
                     SortMode="SortMode.Single"
                     RowsPerPage="25">
            <Columns>
                <PropertyColumn Property="x => x.FechaRegistro"
                                Title="Fecha"
                                Sortable="true"
                                InitialDirection="SortDirection.Descending">
                    <CellTemplate>
                        @context.Item.FechaRegistro.ToString("dd/MM/yyyy")
                    </CellTemplate>
                </PropertyColumn>
                <TemplateColumn Title="AM" Sortable="false" CellStyle="white-space:nowrap;">
                    <CellTemplate>
                        @if (context.Item.HoraEntradaAM.HasValue && context.Item.HoraSalidaAM.HasValue)
                        {
                            @($"{context.Item.HoraEntradaAM.Value:HH\\:mm} – {context.Item.HoraSalidaAM.Value:HH\\:mm}")
                        }
                        else
                        {
                            <MudText Color="Color.Secondary">—</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="PM" Sortable="false" CellStyle="white-space:nowrap;">
                    <CellTemplate>
                        @if (context.Item.HoraEntradaPM.HasValue && context.Item.HoraSalidaPM.HasValue)
                        {
                            @($"{context.Item.HoraEntradaPM.Value:HH\\:mm} – {context.Item.HoraSalidaPM.Value:HH\\:mm}")
                        }
                        else
                        {
                            <MudText Color="Color.Secondary">—</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Cliente" Title="Cliente" />
                <PropertyColumn Property="x => x.Proyecto" Title="Proyecto" />
                <PropertyColumn Property="x => x.Modalidad" Title="Modalidad" Sortable="false" />
                <PropertyColumn Property="x => x.Descripcion" Title="Descripción" Sortable="false" />
                <TemplateColumn Title="" Sortable="false">
                    <CellTemplate>
                        @if (_puedeEditar)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           aria-label="Editar descripción"
                                           Disabled="_isEditing"
                                           OnClick="@(() => AbrirEditarDescripcionAsync(context.Item))" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       aria-label="Eliminar registro"
                                       Disabled="_isDeleting"
                                       OnClick="@(() => ConfirmarEliminarAsync(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }

    <MudMessageBox @ref="_msgBox"
                   Title="Eliminar registro"
                   CancelText="Cancelar">
        <MessageContent>
            ¿Eliminar el registro del
            <b>@_pendiente?.FechaRegistro.ToString("dd/MM/yyyy")</b>?
            Esta acción no se puede deshacer.
        </MessageContent>
        <YesButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled">Eliminar</MudButton>
        </YesButton>
    </MudMessageBox>
</MudStack>

@code {
    private List<HistorialRegistroResponse> _registros = [];
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _successMessage;
    private bool _isDeleting;
    private bool _isEditing;
    private bool _puedeEditar;
    private HistorialRegistroResponse? _pendiente;
    private MudMessageBox? _msgBox;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _registros = await RegistroHorasRepository.GetHistorialAsync();
            _puedeEditar = await CurrentUserService.IsInRoleAsync(Roles.Supervisor)
                        || await CurrentUserService.IsInRoleAsync(Roles.Admin);
        }
        catch
        {
            _errorMessage = "No fue posible cargar el historial. Intente nuevamente.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AbrirEditarDescripcionAsync(HistorialRegistroResponse item)
    {
        var parameters = new DialogParameters<KpgEditDescripcionDialog>
        {
            { x => x.DescripcionActual, item.Descripcion }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<KpgEditDescripcionDialog>(
            "Editar descripción", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string nuevaDescripcion })
            await GuardarDescripcionAsync(item, nuevaDescripcion);
    }

    private async Task GuardarDescripcionAsync(HistorialRegistroResponse item, string nuevaDescripcion)
    {
        _isEditing = true;
        _successMessage = null;
        _errorMessage = null;
        try
        {
            var ok = await RegistroHorasRepository.UpdateDescripcionAsync(item.Id, nuevaDescripcion);
            if (ok)
            {
                var idx = _registros.IndexOf(item);
                if (idx >= 0)
                    _registros[idx] = item with { Descripcion = nuevaDescripcion };
                _successMessage = "Descripción actualizada correctamente.";
            }
            else
            {
                _errorMessage = "No fue posible actualizar la descripción. Intente nuevamente.";
            }
        }
        catch
        {
            _errorMessage = "Ocurrió un error al actualizar la descripción.";
        }
        finally
        {
            _isEditing = false;
        }
    }

    private async Task ConfirmarEliminarAsync(HistorialRegistroResponse item)
    {
        _pendiente = item;
        StateHasChanged();
        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed == true)
            await EliminarAsync(item);
        _pendiente = null;
    }

    private async Task EliminarAsync(HistorialRegistroResponse item)
    {
        _isDeleting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var success = await RegistroHorasRepository.DeleteAsync(item.Id);
            if (success)
            {
                _registros.Remove(item);
                _successMessage = $"Registro del {item.FechaRegistro:dd/MM/yyyy} eliminado.";
            }
            else
            {
                _errorMessage = "No fue posible eliminar el registro. Intente nuevamente.";
            }
        }
        catch
        {
            _errorMessage = "Ocurrió un error al eliminar el registro.";
        }
        finally
        {
            _isDeleting = false;
        }
    }
}
