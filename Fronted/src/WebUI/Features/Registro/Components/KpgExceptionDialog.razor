<MudDialog>
    <TitleContent>
        <div style="background-color: #FFF8E1; margin: -20px -24px 0; padding: 16px 24px; border-radius: 4px 4px 0 0;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Warning" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="font-weight:600;">Solicitar autorización</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@Fecha.ToString("dd/MM/yyyy")</MudText>
                </MudStack>
            </MudStack>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-4">
            Esta fecha está fuera de la ventana de registro permitida.
            Describe el motivo para que un administrador pueda aprobarla.
        </MudText>
        <MudTextField @ref="_justificacionField"
                      T="string"
                      Label="Justificación"
                      Variant="Variant.Outlined"
                      Lines="4"
                      @bind-Value="_justificacion"
                      MaxLength="1000"
                      Counter="1000"
                      Required="true"
                      RequiredError="La justificación es requerida."
                      aria-label="Justificación de la solicitud de excepción" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   Disabled="@string.IsNullOrWhiteSpace(_justificacion)"
                   OnClick="Submit">
            Enviar solicitud
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DateOnly Fecha { get; set; }

    private MudTextField<string> _justificacionField = default!;
    private string _justificacion = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await _justificacionField.FocusAsync();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(_justificacion));
}
