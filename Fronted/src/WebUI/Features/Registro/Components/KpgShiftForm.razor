@inject IRegistroHorasRepository RegistroHorasRepository
@inject IParametroSistemaRepository ParametroSistemaRepository
@inject IDialogService DialogService
@inject ISolicitudExcepcionRepository SolicitudExcepcionRepository
@inject IEmpleadoRepository EmpleadoRepository
@inject IClienteRepository ClienteRepository
@inject IModalidadRepository ModalidadRepository
@inject ILugarTrabajoRepository LugarTrabajoRepository

<MudPaper Elevation="1" Class="pa-6">
    <MudStack Spacing="4">
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
        }

        @if (_guardado)
        {
            <MudAlert Severity="Severity.Success" role="status" Icon="@Icons.Material.Filled.EventAvailable">
                <MudText Typo="Typo.body1"><b>Jornada guardada</b> — @_fecha?.ToString("dd/MM/yyyy")</MudText>
                <MudText Typo="Typo.body2">Total: @TotalHorasFormateado horas</MudText>
            </MudAlert>
        }

        <KpgDatePicker Label="Fecha"
                       WindowDays="@_windowDays"
                       Date="@_fecha"
                       OnDateSelected="HandleDateSelected"
                       OnExceptionRequested="HandleExceptionRequested" />

        @if (_dateAvailability == DateAvailability.OutOfWindow && _fecha.HasValue)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-1">
                Esta fecha está fuera de la ventana de registro permitida (@_windowDays días hábiles).
                <MudButton Variant="Variant.Text" Color="Color.Warning" Size="Size.Small"
                           OnClick="@(() => HandleExceptionRequested(DateOnly.FromDateTime(_fecha!.Value)))"
                           Class="ml-2">
                    Solicitar excepción
                </MudButton>
            </MudAlert>
        }

        @if (_excepcionEnviada)
        {
            <MudAlert Severity="Severity.Success" Dense="true" Class="mt-1">
                Solicitud de excepción enviada para @_excepcionFecha.ToString("dd/MM/yyyy").
            </MudAlert>
        }

        <KpgRecentSuggestions OnSuggestionSelected="HandleSuggestionSelected" />

        <MudForm @ref="_form" @bind-IsValid="_formIsValid">

            @* ── Turno AM ──────────────────────────────────── *@
            <MudText Typo="Typo.subtitle2" Class="mb-1 mt-2" Color="Color.Primary">Turno AM</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Entrada"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Time"
                                  Value="@TsToStr(_model.HoraEntradaAM)"
                                  ValueChanged="@(v => _model.HoraEntradaAM = ParseTs(v))"
                                  aria-label="Hora entrada turno AM" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Salida"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Time"
                                  Value="@TsToStr(_model.HoraSalidaAM)"
                                  ValueChanged="@(v => _model.HoraSalidaAM = ParseTs(v))"
                                  Error="@IsInvalidAM()"
                                  ErrorText="La salida debe ser mayor que la entrada."
                                  aria-label="Hora salida turno AM" />
                </MudItem>
            </MudGrid>

            @* ── Turno PM ──────────────────────────────────── *@
            <MudText Typo="Typo.subtitle2" Class="mb-1 mt-3" Color="Color.Primary">Turno PM</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Entrada"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Time"
                                  Value="@TsToStr(_model.HoraEntradaPM)"
                                  ValueChanged="@(v => _model.HoraEntradaPM = ParseTs(v))"
                                  aria-label="Hora entrada turno PM" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Salida"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Time"
                                  Value="@TsToStr(_model.HoraSalidaPM)"
                                  ValueChanged="@(v => _model.HoraSalidaPM = ParseTs(v))"
                                  Error="@IsInvalidPM()"
                                  ErrorText="La salida debe ser mayor que la entrada."
                                  aria-label="Hora salida turno PM" />
                </MudItem>
            </MudGrid>

            @if (_sinTurno)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-1">
                    Debe ingresar al menos una hora de entrada en el turno AM o PM.
                </MudAlert>
            }

            @* ── Datos del día ──────────────────────────────── *@
            <MudText Typo="Typo.subtitle2" Class="mb-1 mt-3" Color="Color.Primary">Datos del día</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="6">
                    <MudAutocomplete T="string"
                                     Label="Cliente"
                                     Variant="Variant.Outlined"
                                     Value="@_model.Cliente"
                                     ValueChanged="@(v => HandleClienteChanged(v))"
                                     SearchFunc="@SearchClientesAsync"
                                     Required="true"
                                     RequiredError="El cliente es requerido."
                                     CoerceValue="true"
                                     Immediate="false" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudAutocomplete T="string"
                                     Label="Proyecto"
                                     Variant="Variant.Outlined"
                                     @bind-Value="_model.Proyecto"
                                     SearchFunc="@SearchProyectosAsync"
                                     Required="true"
                                     RequiredError="El proyecto es requerido."
                                     CoerceValue="true"
                                     Immediate="false" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText id="modalidad-label" Typo="Typo.body2" Class="mb-1">Modalidad *</MudText>
                    <div role="radiogroup" aria-labelledby="modalidad-label"
                         style="display:flex;gap:6px;flex-wrap:wrap;">
                        @foreach (var m in _modalidades)
                        {
                            var isSelected = _model.Modalidad == m;
                            var isFirst = _modalidades.Count > 0 && m == _modalidades[0];
                            var tabIdx = isSelected || (string.IsNullOrWhiteSpace(_model.Modalidad) && isFirst) ? 0 : -1;
                            <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       role="radio"
                                       aria-checked="@(isSelected ? "true" : "false")"
                                       tabindex="@tabIdx"
                                       @onkeydown="@(e => HandleModalidadKey(e))"
                                       OnClick="@(() => { _model.Modalidad = m; _touchedModalidad = true; StateHasChanged(); })">
                                @m
                            </MudButton>
                        }
                    </div>
                    @if (string.IsNullOrWhiteSpace(_model.Modalidad) && _touchedModalidad)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">La modalidad es requerida.</MudText>
                    }
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Recurso" Variant="Variant.Outlined"
                               @bind-Value="_model.Recurso" Required="true" RequiredError="El recurso es requerido.">
                        @foreach (var r in _recursos)
                        {
                            <MudSelectItem Value="@r">@r</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="string" Label="Lugar" Variant="Variant.Outlined"
                               @bind-Value="_model.Lugar" Required="true" RequiredError="El lugar es requerido.">
                        @foreach (var l in _lugares)
                        {
                            <MudSelectItem Value="@l">@l</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Descripcion" Variant="Variant.Outlined"
                                  Lines="3" @bind-Value="_model.Descripcion"
                                  Required="true" RequiredError="La descripcion es requerida." />
                </MudItem>
            </MudGrid>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Disabled="@_isSaving"
                       OnClick="SaveAsync"
                       Class="mt-4">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Guardando...</span>
                }
                else
                {
                    <span>Guardar jornada</span>
                }
            </MudButton>
        </MudForm>
    </MudStack>
</MudPaper>

@code {
    private MudForm _form = default!;

    private DateTime? _fecha = DateTime.Today;
    private bool _formIsValid;
    private bool _isSaving;
    private bool _guardado;
    private bool _sinTurno;
    private bool _touchedModalidad;
    private string? _errorMessage;
    private int _windowDays = 3;
    private DateAvailability _dateAvailability = DateAvailability.Available;
    private bool _excepcionEnviada;
    private DateOnly _excepcionFecha;

    private RegistroHorasResponse? _response;

    private readonly DayFormModel _model = new();

    private static readonly string[] ClientesFallback  = ["KPG", "Cliente interno", "Cliente externo"];
    private static readonly string[] ProyectosFallback = ["Timesheet", "Soporte operativo", "Consultoría"];
    private static readonly string[] ModalidadesFallback = ["Presencial", "Remoto", "Híbrido"];
    private static readonly string[] RecursosFallback  = ["Consultor", "Analista", "Líder técnico"];
    private static readonly string[] LugaresFallback   = ["Presencial Oficina", "Presencial Viaje", "Presencial Cliente", "Remoto"];

    private List<ClienteConProyectosResponse> _catalogoClientes = [];
    private List<RegistroRecienteResponse> _sugerenciasRecientes = [];
    private List<string> _modalidades = [.. ModalidadesFallback];
    private List<string> _recursos    = [];
    private List<string> _lugares     = [.. LugaresFallback];

    private string TotalHorasFormateado
    {
        get
        {
            if (_response is null) return string.Empty;
            int totalMin = 0;
            if (_response.HoraEntradaAM.HasValue && _response.HoraSalidaAM.HasValue)
                totalMin += (int)(_response.HoraSalidaAM.Value - _response.HoraEntradaAM.Value).TotalMinutes;
            if (_response.HoraEntradaPM.HasValue && _response.HoraSalidaPM.HasValue)
                totalMin += (int)(_response.HoraSalidaPM.Value - _response.HoraEntradaPM.Value).TotalMinutes;
            return $"{totalMin / 60:D2}:{totalMin % 60:D2}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try { _sugerenciasRecientes = await RegistroHorasRepository.GetRecientesAsync(5); } catch { }
        try { _windowDays = await ParametroSistemaRepository.GetVentanaRetroactividadAsync(); } catch { _windowDays = 3; }

        try
        {
            var activos = await EmpleadoRepository.GetActivosAsync();
            _recursos = activos.Select(e => e.Nombre).ToList();
            if (_recursos.Count == 0) _recursos = [.. RecursosFallback];
        }
        catch { _recursos = [.. RecursosFallback]; }

        try { _catalogoClientes = await ClienteRepository.GetCatalogoAsync(); } catch { }

        try
        {
            var mods = await ModalidadRepository.GetActivasAsync();
            if (mods.Count > 0) _modalidades = mods.Select(m => m.Nombre).ToList();
        }
        catch { }

        try
        {
            var lugares = await LugarTrabajoRepository.GetActivosAsync();
            if (lugares.Count > 0) _lugares = lugares.Select(l => l.Nombre).ToList();
        }
        catch { }
    }

    private void HandleSuggestionSelected(RegistroRecienteResponse s)
    {
        _model.Cliente    = s.Cliente;
        _model.Proyecto   = s.Proyecto;
        _model.Modalidad  = s.Modalidad;
        _model.Recurso    = s.Recurso;
        _model.Lugar      = s.Lugar;
        _model.Descripcion = s.Descripcion;
        StateHasChanged();
    }

    private Task<IEnumerable<string>> SearchClientesAsync(string text, CancellationToken token)
    {
        var opciones = _sugerenciasRecientes
            .Select(s => s.Cliente)
            .Concat(_catalogoClientes.Count > 0
                ? _catalogoClientes.Select(c => c.Nombre)
                : ClientesFallback)
            .Distinct(StringComparer.OrdinalIgnoreCase);

        return Task.FromResult(string.IsNullOrWhiteSpace(text)
            ? opciones
            : opciones.Where(c => c.Contains(text, StringComparison.OrdinalIgnoreCase)));
    }

    private Task<IEnumerable<string>> SearchProyectosAsync(string text, CancellationToken token)
    {
        var sugsCliente = string.IsNullOrWhiteSpace(_model.Cliente)
            ? Enumerable.Empty<string>()
            : _sugerenciasRecientes
                .Where(s => s.Cliente.Equals(_model.Cliente, StringComparison.OrdinalIgnoreCase))
                .Select(s => s.Proyecto)
                .Distinct(StringComparer.OrdinalIgnoreCase);

        IEnumerable<string> opciones;
        if (!string.IsNullOrWhiteSpace(_model.Cliente))
        {
            var entrada = _catalogoClientes
                .FirstOrDefault(c => c.Nombre.Equals(_model.Cliente, StringComparison.OrdinalIgnoreCase));
            var base_ = entrada is not null
                ? entrada.ProyectosActivos.AsEnumerable()
                : sugsCliente.Any() ? sugsCliente : ProyectosFallback.AsEnumerable();
            opciones = sugsCliente.Concat(base_).Distinct(StringComparer.OrdinalIgnoreCase);
        }
        else
        {
            opciones = _catalogoClientes.Count > 0
                ? _catalogoClientes.SelectMany(c => c.ProyectosActivos).Distinct(StringComparer.OrdinalIgnoreCase)
                : ProyectosFallback;
        }

        return Task.FromResult(string.IsNullOrWhiteSpace(text)
            ? opciones
            : opciones.Where(p => p.Contains(text, StringComparison.OrdinalIgnoreCase)));
    }

    private void HandleClienteChanged(string? value)
    {
        _model.Cliente  = value;
        _model.Proyecto = null;
        StateHasChanged();
    }

    private static string TsToStr(TimeSpan? t) =>
        t.HasValue ? t.Value.ToString(@"hh\:mm") : string.Empty;

    private static TimeSpan? ParseTs(string? s) =>
        TimeSpan.TryParse(s, out var t) ? t : null;

    private bool IsInvalidAM() =>
        _model.HoraEntradaAM.HasValue && _model.HoraSalidaAM.HasValue &&
        _model.HoraSalidaAM.Value <= _model.HoraEntradaAM.Value;

    private bool IsInvalidPM() =>
        _model.HoraEntradaPM.HasValue && _model.HoraSalidaPM.HasValue &&
        _model.HoraSalidaPM.Value <= _model.HoraEntradaPM.Value;

    private bool TieneAlMenosUnTurno() =>
        _model.HoraEntradaAM.HasValue || _model.HoraEntradaPM.HasValue;

    private void HandleModalidadKey(KeyboardEventArgs e)
    {
        if (e.Key is not ("ArrowLeft" or "ArrowRight" or "ArrowUp" or "ArrowDown") || _modalidades.Count == 0)
            return;
        var current = _modalidades.IndexOf(_model.Modalidad ?? _modalidades[0]);
        if (current < 0) current = 0;
        _model.Modalidad = e.Key is "ArrowRight" or "ArrowDown"
            ? _modalidades[(current + 1) % _modalidades.Count]
            : _modalidades[(current - 1 + _modalidades.Count) % _modalidades.Count];
        StateHasChanged();
    }

    private void HandleDateSelected((DateTime? Date, DateAvailability Availability) selection)
    {
        _fecha            = selection.Date;
        _dateAvailability = selection.Availability;
        _guardado         = false;
        _response         = null;
        _sinTurno         = false;
        _errorMessage     = null;
        _excepcionEnviada = false;
    }

    private async Task HandleExceptionRequested(DateOnly fecha)
    {
        var parameters = new DialogParameters<KpgExceptionDialog> { { x => x.Fecha, fecha } };
        var options    = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog     = await DialogService.ShowAsync<KpgExceptionDialog>(string.Empty, parameters, options);
        var result     = await dialog.Result;

        if (result is { Canceled: false, Data: string justificacion } && !string.IsNullOrWhiteSpace(justificacion))
        {
            try
            {
                await SolicitudExcepcionRepository.CreateAsync(
                    new CreateSolicitudExcepcionRequest(fecha, justificacion));
                _excepcionEnviada = true;
                _excepcionFecha   = fecha;
            }
            catch { _errorMessage = "No fue posible enviar la solicitud de excepción. Intente nuevamente."; }
        }
    }

    private async Task SaveAsync()
    {
        _touchedModalidad = true;
        await _form.Validate();
        _sinTurno = false;

        // Validaciones propias
        if (!TieneAlMenosUnTurno())       { _sinTurno = true; return; }
        if (IsInvalidAM() || IsInvalidPM()) return;
        if (!_form.IsValid) return;
        if (string.IsNullOrWhiteSpace(_model.Modalidad)) return;
        if (_dateAvailability == DateAvailability.OutOfWindow) return;
        if (!_fecha.HasValue) return;

        _isSaving     = true;
        _errorMessage = null;

        try
        {
            var request = new CreateRegistroHorasRequest(
                DateOnly.FromDateTime(_fecha!.Value),
                _model.HoraEntradaAM.HasValue ? TimeOnly.FromTimeSpan(_model.HoraEntradaAM.Value) : null,
                _model.HoraSalidaAM.HasValue  ? TimeOnly.FromTimeSpan(_model.HoraSalidaAM.Value)  : null,
                _model.HoraEntradaPM.HasValue ? TimeOnly.FromTimeSpan(_model.HoraEntradaPM.Value) : null,
                _model.HoraSalidaPM.HasValue  ? TimeOnly.FromTimeSpan(_model.HoraSalidaPM.Value)  : null,
                _model.Cliente!,
                _model.Proyecto!,
                _model.Modalidad!,
                _model.Recurso!,
                _model.Descripcion!,
                _model.Lugar!);

            _response = await RegistroHorasRepository.CreateAsync(request);
            if (_response is null)
            {
                _errorMessage = "No fue posible guardar la jornada. Revise los datos e intente nuevamente.";
                return;
            }
            _guardado = true;
        }
        catch (UnauthorizedAccessException) { _errorMessage = "Su sesión expiró. Inicie sesión nuevamente."; }
        catch { _errorMessage = "Ocurrió un error guardando la jornada."; }
        finally { _isSaving = false; }
    }

    private sealed class DayFormModel
    {
        public TimeSpan? HoraEntradaAM { get; set; }
        public TimeSpan? HoraSalidaAM  { get; set; }
        public TimeSpan? HoraEntradaPM { get; set; }
        public TimeSpan? HoraSalidaPM  { get; set; }
        public string?   Cliente     { get; set; }
        public string?   Proyecto    { get; set; }
        public string?   Modalidad   { get; set; }
        public string?   Recurso     { get; set; }
        public string?   Descripcion { get; set; }
        public string?   Lugar       { get; set; }
    }
}
