@page "/dashboard"
@attribute [Authorize(Roles = $"{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")]
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject IDashboardRepository Repo

<PageTitle>Dashboard - KPG Timesheet</PageTitle>

<MudStack Spacing="4">

    {{!-- ── Encabezado ─────────────────────────────────────────────── --}}
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
        <div>
            <MudText Typo="Typo.h4" Style="font-family:Poppins,sans-serif;font-weight:600;">Dashboard</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Estado diario del equipo</MudText>
        </div>
        <MudDatePicker Label="Fecha"
                       Date="_fechaDate"
                       DateChanged="OnFechaChangedAsync"
                       MaxDate="DateTime.Today"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="max-width:180px;" />
    </MudStack>

    {{!-- ── Sección: Estado diario ─────────────────────────────────── --}}
    @if (_isLoadingEstado)
    {
        <MudGrid>
            @for (var i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudSkeleton Width="100%" Height="90px" SkeletonType="SkeletonType.Rectangle" Style="border-radius:12px;" />
                </MudItem>
            }
        </MudGrid>
        <KpgTableSkeleton Rows="6" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorEstado))
    {
        <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorEstado</MudAlert>
    }
    else if (_estado is not null)
    {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <KpgStatCard Label="Total empleados" Value="_estado.TotalEmpleados"
                             Icon="@Icons.Material.Filled.People" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpgStatCard Label="Completo" Value="_estado.TotalCompletos"
                             Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpgStatCard Label="Parcial" Value="_estado.TotalParciales"
                             Icon="@Icons.Material.Filled.Pending" Color="Color.Warning" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpgStatCard Label="Pendiente" Value="_estado.TotalPendientes"
                             Icon="@Icons.Material.Filled.HourglassEmpty" Color="Color.Default" />
            </MudItem>
        </MudGrid>

        @if (_estado.Equipo.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No hay miembros del equipo registrados.</MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var miembro in _estado.Equipo)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <KpgTeamStatusCard Nombre="@miembro.Nombre"
                                           Estado="@miembro.Estado"
                                           TieneAm="@miembro.TieneAm"
                                           TienePm="@miembro.TienePm" />
                    </MudItem>
                }
            </MudGrid>
        }
    }

    <MudDivider />

    {{!-- ── Sección: Distribución de horas ────────────────────────── --}}
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6" Style="font-weight:600;">Distribución de horas</MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" OverrideStyles="false">
                    <MudButton Color="@(_periodo == Periodo.Hoy ? Color.Primary : Color.Default)"
                               OnClick="@(() => CambiarPeriodoAsync(Periodo.Hoy))">Hoy</MudButton>
                    <MudButton Color="@(_periodo == Periodo.Semana ? Color.Primary : Color.Default)"
                               OnClick="@(() => CambiarPeriodoAsync(Periodo.Semana))">Esta semana</MudButton>
                    <MudButton Color="@(_periodo == Periodo.Mes ? Color.Primary : Color.Default)"
                               OnClick="@(() => CambiarPeriodoAsync(Periodo.Mes))">Este mes</MudButton>
                    <MudButton Color="@(_periodo == Periodo.Personalizado ? Color.Primary : Color.Default)"
                               OnClick="@(() => CambiarPeriodoAsync(Periodo.Personalizado))">Personalizado</MudButton>
                </MudButtonGroup>
                @if (_periodo == Periodo.Personalizado)
                {
                    <MudDateRangePicker DateRange="_rangoPersonalizado"
                                        DateRangeChanged="OnRangoPersonalizadoChangedAsync"
                                        MaxDate="DateTime.Today"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Dense"
                                        Style="max-width:280px;" />
                }
            </MudStack>
        </MudStack>

        @if (_isLoadingDistribucion)
        {
            <MudSkeleton Width="100%" Height="300px" SkeletonType="SkeletonType.Rectangle" Style="border-radius:12px;" />
        }
        else if (!string.IsNullOrWhiteSpace(_errorDistribucion))
        {
            <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorDistribucion</MudAlert>
        }
        else if (_distribucion is not null)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.AccessTime" Color="Color.Primary" Size="Size.Small" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Total equipo: <strong>@_distribucion.TotalHorasEquipo.ToString("F1") h</strong>
                    (@_distribucion.Desde.ToString("dd/MM") – @_distribucion.Hasta.ToString("dd/MM/yyyy"))
                </MudText>
            </MudStack>

            @if (_distribucion.Consultores.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No hay registros de horas en el período seleccionado.</MudAlert>
            }
            else
            {
                <MudPaper Elevation="2" Class="pa-3" Style="border-radius:12px;">
                    <ApexChart TItem="DistribucionConsultorDto"
                               Title=""
                               Options="_chartOptions"
                               Height="@Math.Max(200, _distribucion.Consultores.Count * 48)">
                        <ApexPointSeries TItem="DistribucionConsultorDto"
                                         Items="_distribucion.Consultores"
                                         Name="Horas"
                                         XValue="@(e => e.Nombre)"
                                         YValue="@(e => e.TotalHoras)"
                                         SeriesType="SeriesType.Bar" />
                    </ApexChart>
                </MudPaper>
            }
        }
    </MudStack>

    {{!-- ── Sección gerencial (Gerente / Admin) ───────────────────── --}}
    <AuthorizeView Roles="@($"{Roles.Gerente},{Roles.Admin}")">
        <Authorized>
            <MudDivider />
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Primary" />
                        <MudText Typo="Typo.h6" Style="font-weight:600;">Vista gerencial</MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Período: @_distribucion?.Desde.ToString("dd/MM") – @_distribucion?.Hasta.ToString("dd/MM/yyyy")
                    </MudText>
                </MudStack>

                @if (_isLoadingGerencial)
                {
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudSkeleton Width="100%" Height="300px" SkeletonType="SkeletonType.Rectangle" Style="border-radius:12px;" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSkeleton Width="100%" Height="300px" SkeletonType="SkeletonType.Rectangle" Style="border-radius:12px;" />
                        </MudItem>
                    </MudGrid>
                }
                else if (!string.IsNullOrWhiteSpace(_errorGerencial))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorGerencial</MudAlert>
                }
                else if (_gerencial is not null)
                {
                    <MudGrid>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-4" Elevation="2" Style="border-radius:12px;">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total horas</MudText>
                                    <MudText Typo="Typo.h4" Style="font-weight:700;">@_gerencial.TotalHoras.ToString("F1") h</MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-4" Elevation="2" Style="border-radius:12px;">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Clientes activos</MudText>
                                    <MudText Typo="Typo.h4" Style="font-weight:700;">@_gerencial.TotalClientes</MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        @if (_gerencial.PorCliente.Count > 0)
                        {
                            <MudItem xs="12" sm="12" md="6">
                                <MudPaper Class="pa-4" Elevation="2" Style="border-radius:12px;">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Top cliente</MudText>
                                        <MudText Typo="Typo.h6" Style="font-weight:600;">@_gerencial.PorCliente[0].Cliente</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_gerencial.PorCliente[0].TotalHoras.ToString("F1") h</MudText>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>

                    @if (_gerencial.PorCliente.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info">No hay registros de horas en el período seleccionado.</MudAlert>
                    }
                    else
                    {
                        <MudGrid>
                            <MudItem xs="12" md="5">
                                <MudPaper Elevation="2" Class="pa-3" Style="border-radius:12px;">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Horas por cliente</MudText>
                                    <ApexChart TItem="HorasPorClienteDto"
                                               Options="_donutOptions"
                                               Height="280">
                                        <ApexPointSeries TItem="HorasPorClienteDto"
                                                         Items="_gerencial.PorCliente"
                                                         Name="Horas"
                                                         XValue="@(e => e.Cliente)"
                                                         YValue="@(e => e.TotalHoras)"
                                                         SeriesType="SeriesType.Donut" />
                                    </ApexChart>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" md="7">
                                <MudPaper Elevation="2" Class="pa-3" Style="border-radius:12px;">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Horas por proyecto</MudText>
                                    <ApexChart TItem="HorasPorProyectoDto"
                                               Options="_barProyectoOptions"
                                               Height="@Math.Max(200, _gerencial.PorProyecto.Count * 40)">
                                        <ApexPointSeries TItem="HorasPorProyectoDto"
                                                         Items="_gerencial.PorProyecto"
                                                         Name="Horas"
                                                         XValue="@(e => e.Proyecto)"
                                                         YValue="@(e => e.TotalHoras)"
                                                         SeriesType="SeriesType.Bar" />
                                    </ApexChart>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    }
                }
            </MudStack>
        </Authorized>
    </AuthorizeView>

</MudStack>

@code {
    // ── Estado diario ────────────────────────────────────────────────
    private EstadoEquipoResponse? _estado;
    private bool _isLoadingEstado = true;
    private string _errorEstado = string.Empty;
    private DateOnly _fecha = DateOnly.FromDateTime(DateTime.Today);
    private DateTime? _fechaDate => _fecha.ToDateTime(TimeOnly.MinValue);

    // ── Distribución de horas ────────────────────────────────────────
    private DistribucionHorasResponse? _distribucion;
    // ── Dashboard gerencial ──────────────────────────────────────────
    private DashboardGerencialResponse? _gerencial;
    private bool _isLoadingGerencial = true;
    private string _errorGerencial = string.Empty;
    private bool _isLoadingDistribucion = true;
    private string _errorDistribucion = string.Empty;
    private Periodo _periodo = Periodo.Semana;
    private DateRange _rangoPersonalizado = new(DateTime.Today.AddDays(-6), DateTime.Today);

    private ApexChartOptions<DistribucionConsultorDto> _chartOptions = new()
    {
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar { Horizontal = true, BorderRadius = 4 }
        },
        Xaxis = new XAxis { Title = new AxisTitle { Text = "Horas" } },
        DataLabels = new DataLabels { Enabled = true },
        Legend = new Legend { Show = false },
        Grid = new Grid { BorderColor = "#e0e0e0" }
    };

    private ApexChartOptions<HorasPorClienteDto> _donutOptions = new()
    {
        DataLabels = new DataLabels { Enabled = true },
        Legend = new Legend { Position = LegendPosition.Bottom }
    };

    private ApexChartOptions<HorasPorProyectoDto> _barProyectoOptions = new()
    {
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar { Horizontal = true, BorderRadius = 4 }
        },
        DataLabels = new DataLabels { Enabled = true },
        Legend = new Legend { Show = false },
        Grid = new Grid { BorderColor = "#e0e0e0" }
    };

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(CargarEstadoAsync(), CargarDistribucionAsync(), CargarGerencialAsync());
    }

    private async Task OnFechaChangedAsync(DateTime? date)
    {
        if (date is null) return;
        _fecha = DateOnly.FromDateTime(date.Value);
        await CargarEstadoAsync();
    }

    private async Task CambiarPeriodoAsync(Periodo periodo)
    {
        _periodo = periodo;
        await Task.WhenAll(CargarDistribucionAsync(), CargarGerencialAsync());
    }

    private async Task OnRangoPersonalizadoChangedAsync(DateRange rango)
    {
        _rangoPersonalizado = rango;
        if (rango.Start.HasValue && rango.End.HasValue)
            await Task.WhenAll(CargarDistribucionAsync(), CargarGerencialAsync());
    }

    private async Task CargarEstadoAsync()
    {
        _isLoadingEstado = true;
        _errorEstado = string.Empty;
        StateHasChanged();
        try
        {
            _estado = await Repo.GetEstadoEquipoAsync(_fecha);
            if (_estado is null) _errorEstado = "No se pudo obtener el estado del equipo.";
        }
        catch { _errorEstado = "Error al comunicarse con el servidor."; }
        finally { _isLoadingEstado = false; }
    }

    private async Task CargarDistribucionAsync()
    {
        _isLoadingDistribucion = true;
        _errorDistribucion = string.Empty;
        StateHasChanged();
        try
        {
            var (desde, hasta) = ObtenerRango();
            _distribucion = await Repo.GetDistribucionHorasAsync(desde, hasta);
            if (_distribucion is null) _errorDistribucion = "No se pudo obtener la distribución de horas.";
        }
        catch { _errorDistribucion = "Error al comunicarse con el servidor."; }
        finally { _isLoadingDistribucion = false; }
    }

    private (DateOnly desde, DateOnly hasta) ObtenerRango()
    {
        var hoy = DateOnly.FromDateTime(DateTime.Today);
        return _periodo switch
        {
            Periodo.Hoy          => (hoy, hoy),
            Periodo.Semana       => (InicioSemana(hoy), hoy),
            Periodo.Mes          => (new DateOnly(hoy.Year, hoy.Month, 1), hoy),
            Periodo.Personalizado => (
                _rangoPersonalizado.Start.HasValue ? DateOnly.FromDateTime(_rangoPersonalizado.Start.Value) : hoy.AddDays(-6),
                _rangoPersonalizado.End.HasValue   ? DateOnly.FromDateTime(_rangoPersonalizado.End.Value)   : hoy),
            _ => (hoy, hoy)
        };
    }

    private async Task CargarGerencialAsync()
    {
        _isLoadingGerencial = true;
        _errorGerencial = string.Empty;
        StateHasChanged();
        try
        {
            var (desde, hasta) = ObtenerRango();
            _gerencial = await Repo.GetDashboardGerencialAsync(desde, hasta);
            if (_gerencial is null) _errorGerencial = "No se pudo obtener el dashboard gerencial.";
        }
        catch { _errorGerencial = "Error al comunicarse con el servidor."; }
        finally { _isLoadingGerencial = false; }
    }

    private static DateOnly InicioSemana(DateOnly fecha)
    {
        var diff = (int)fecha.DayOfWeek - (int)DayOfWeek.Monday;
        if (diff < 0) diff += 7;
        return fecha.AddDays(-diff);
    }

    private enum Periodo { Hoy, Semana, Mes, Personalizado }
}
