@page "/login"
@layout LoginLayout
@inject KpgAuthStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Login_Title"] — KPG Timesheet</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudPaper Class="pa-8" Elevation="4" Style="width: 100%; max-width: 420px;">

        <div class="d-flex flex-column align-center mb-6">
            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-family: Poppins, sans-serif; font-weight: 700;">
                KPG Timesheet
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                @L["Login_Subtitle"]
            </MudText>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
        }

        <MudForm @ref="_form" @bind-IsValid="_formIsValid">
            <MudTextField T="string"
                          Label="@L["Label_Email"]"
                          @bind-Value="_email"
                          InputType="InputType.Email"
                          Required="true"
                          RequiredError="@L["Label_Email"]"
                          Class="mb-3"
                          Variant="Variant.Outlined"
                          ShrinkLabel="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email" />

            <MudTextField T="string"
                          Label="@L["Label_Password"]"
                          @bind-Value="_password"
                          InputType="@_passwordInputType"
                          Required="true"
                          RequiredError="@L["Label_Password"]"
                          Class="mb-4"
                          Variant="Variant.Outlined"
                          ShrinkLabel="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordIcon"
                          OnAdornmentClick="TogglePasswordVisibility" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@_isLoading"
                       OnClick="HandleLogin"
                       Class="mb-4">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>@L["Login_Loading"]</span>
                }
                else
                {
                    <span>@L["Login_Button"]</span>
                }
            </MudButton>
        </MudForm>

        <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="mt-1">
            <MudLink Href="/forgot-password" Typo="Typo.body2" Color="Color.Primary">
                @L["Login_ForgotPassword"]
            </MudLink>
        </MudStack>

        <MudDivider Class="my-2" />

        <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-3" Color="Color.Secondary">
            @L["Login_ContactAdmin"]
        </MudText>

    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = default!;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string? _errorMessage;
    private bool _isLoading;
    private bool _formIsValid;
    private bool _showPassword;

    private InputType _passwordInputType => _showPassword ? InputType.Text : InputType.Password;
    private string _passwordIcon => _showPassword
        ? Icons.Material.Filled.Visibility
        : Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private async Task HandleLogin()
    {
        await _form.Validate();
        if (!_formIsValid) return;

        _isLoading = true;
        _errorMessage = null;

        try
        {
            await AuthProvider.LoginAsync(_email, _password);

            Navigation.NavigateTo("/");
        }
        catch (UnauthorizedAccessException)
        {
            _errorMessage = L["Login_Error"];
        }
        catch
        {
            _errorMessage = L["Error_Server"];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
