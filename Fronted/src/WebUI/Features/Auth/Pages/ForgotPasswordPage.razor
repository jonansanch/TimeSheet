@page "/forgot-password"
@layout LoginLayout
@inject IAuthRepository AuthRepo
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["FP_Title"] - KPG Timesheet</PageTitle>

<MudStack Spacing="4" Style="max-width:400px;margin:0 auto;">
    <div style="text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Primary" Style="font-size:3rem;" />
        <MudText Typo="Typo.h5" Style="font-family:Poppins,sans-serif;font-weight:700;margin-top:8px;">
            @L["FP_Title"]
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @L["FP_Subtitle"]
        </MudText>
    </div>

    @if (_enviado)
    {
        <MudAlert Severity="Severity.Success" role="status">
            @L["FP_Sent"]
        </MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo("/login"))">
            @L["FP_BackToLogin"]
        </MudButton>
    }
    else
    {
        <MudForm @ref="_form" @bind-IsValid="_formIsValid">
            <MudStack Spacing="3">
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
                }

                <MudTextField T="string"
                              @bind-Value="_email"
                              Label="@L["Label_Email"]"
                              InputType="InputType.Email"
                              Required="true"
                              RequiredError="@L["Login_EmailRequired"]"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              Disabled="@_enviando" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@(!_formIsValid || _enviando)"
                           OnClick="EnviarAsync"
                           Style="height:48px;">
                    @if (_enviando)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @L["FP_SendLink"]
                </MudButton>

                <MudLink Href="/login" Typo="Typo.body2" Style="text-align:center;">
                    @L["FP_BackToLogin"]
                </MudLink>
            </MudStack>
        </MudForm>
    }
</MudStack>

@code {
    private MudForm _form = default!;
    private string _email = string.Empty;
    private bool _formIsValid;
    private bool _enviando;
    private bool _enviado;
    private string? _errorMessage;

    private async Task EnviarAsync()
    {
        await _form.Validate();
        if (!_formIsValid) return;

        _enviando = true;
        _errorMessage = null;
        try
        {
            await AuthRepo.ForgotPasswordAsync(_email);
            // Siempre mostramos éxito para no revelar si el email existe
            _enviado = true;
        }
        catch
        {
            _errorMessage = L["Error_Unexpected"];
        }
        finally { _enviando = false; }
    }
}
