@page "/reset-password"
@layout LoginLayout
@inject IAuthRepository AuthRepo
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["RP_Title"] - KPG Timesheet</PageTitle>

<MudStack Spacing="4" Style="max-width:400px;margin:0 auto;">
    <div style="text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.LockOpen" Color="Color.Primary" Style="font-size:3rem;" />
        <MudText Typo="Typo.h5" Style="font-family:Poppins,sans-serif;font-weight:700;margin-top:8px;">
            @L["RP_Title"]
        </MudText>
    </div>

    @if (_tokenInvalido)
    {
        <MudAlert Severity="Severity.Error" aria-live="polite">@L["RP_InvalidLink"]</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo("/forgot-password"))">
            @L["RP_RequestNew"]
        </MudButton>
    }
    else if (_exito)
    {
        <MudAlert Severity="Severity.Success" role="status">@L["RP_Success"]</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   OnClick="@(() => Nav.NavigateTo("/login"))">
            @L["FP_BackToLogin"]
        </MudButton>
    }
    else
    {
        <MudForm @ref="_form" @bind-IsValid="_formIsValid">
            <MudStack Spacing="3">
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" aria-live="polite">@_errorMessage</MudAlert>
                }

                <MudTextField T="string"
                              @bind-Value="_newPassword"
                              Label="@L["Profile_NewPassword"]"
                              InputType="@_inputType"
                              Required="true"
                              RequiredError="@L["Profile_Required"]"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_visibilityIcon"
                              OnAdornmentClick="ToggleVisibility"
                              Disabled="@_procesando" />

                <MudTextField T="string"
                              @bind-Value="_confirmPassword"
                              Label="@L["Profile_ConfirmPassword"]"
                              InputType="@_inputType"
                              Required="true"
                              Validation="@((string v) => v == _newPassword ? null : L["Profile_PasswordMismatch"].Value)"
                              Variant="Variant.Outlined"
                              Disabled="@_procesando" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@(!_formIsValid || _procesando)"
                           OnClick="ResetearAsync"
                           Style="height:48px;">
                    @if (_procesando)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @L["RP_Submit"]
                </MudButton>
            </MudStack>
        </MudForm>
    }
</MudStack>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private MudForm _form = default!;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _formIsValid;
    private bool _procesando;
    private bool _exito;
    private bool _tokenInvalido;
    private string? _errorMessage;
    private InputType _inputType = InputType.Password;
    private string _visibilityIcon = Icons.Material.Filled.Visibility;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
            _tokenInvalido = true;
    }

    private void ToggleVisibility()
    {
        if (_inputType == InputType.Password)
        {
            _inputType = InputType.Text;
            _visibilityIcon = Icons.Material.Filled.VisibilityOff;
        }
        else
        {
            _inputType = InputType.Password;
            _visibilityIcon = Icons.Material.Filled.Visibility;
        }
    }

    private async Task ResetearAsync()
    {
        await _form.Validate();
        if (!_formIsValid) return;

        _procesando = true;
        _errorMessage = null;
        try
        {
            var (ok, error) = await AuthRepo.ResetPasswordAsync(Email!, Token!, _newPassword);
            if (ok)
                _exito = true;
            else
                _errorMessage = error ?? L["RP_InvalidLink"];
        }
        catch
        {
            _errorMessage = L["Error_Unexpected"];
        }
        finally { _procesando = false; }
    }
}
