@inject KpgAuthStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<MudNavMenu Class="kpg-nav" Style="padding:8px 0;">

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home"
                        IconColor="Color.Secondary">
                @L["Nav_Home"]
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.Empleado},{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")">
        <Authorized>
            <MudNavLink Href="/registro"
                        Icon="@Icons.Material.Filled.EditCalendar"
                        IconColor="Color.Secondary">
                @L["Nav_Register"]
            </MudNavLink>
            <MudNavLink Href="/mis-registros"
                        Icon="@Icons.Material.Filled.History"
                        IconColor="Color.Secondary">
                @L["Nav_MyRecords"]
            </MudNavLink>
            <MudNavLink Href="/mis-solicitudes"
                        Icon="@Icons.Material.Filled.AssignmentLate"
                        IconColor="Color.Secondary">
                @L["Nav_MisSolicitudes"]
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")">
        <Authorized>
            <MudNavLink Href="/dashboard"
                        Icon="@Icons.Material.Filled.Dashboard"
                        IconColor="Color.Secondary">
                @L["Nav_Dashboard"]
            </MudNavLink>

            <MudNavGroup Title="@L["Nav_Reports"]"
                         Icon="@Icons.Material.Filled.BarChart"
                         @bind-Expanded="_reportesExpanded">
                <MudNavLink Href="/reportes/horas" Class="kpg-nav-child">
                    @L["Nav_ReporteHoras"]
                </MudNavLink>
                <MudNavLink Href="/reportes/timesheet" Class="kpg-nav-child">
                    @L["Nav_Timesheet"]
                </MudNavLink>
            </MudNavGroup>

            <MudNavLink Href="/notificaciones"
                        Icon="@Icons.Material.Filled.Notifications"
                        IconColor="Color.Secondary">
                @L["Nav_Notifications"]
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.Supervisor},{Roles.Gerente}")">
        <Authorized>
            <MudNavLink Href="/bitacora"
                        Icon="@Icons.Material.Filled.ManageSearch"
                        IconColor="Color.Secondary">
                @L["Nav_Bitacora"]
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@Roles.Admin">
        <Authorized>
            <MudNavGroup Title="@L["Nav_Admin"]"
                         Icon="@Icons.Material.Filled.AdminPanelSettings"
                         @bind-Expanded="_adminExpanded">
                <MudNavLink Href="/admin/usuarios" Class="kpg-nav-child">
                    @L["Nav_Users"]
                </MudNavLink>
                <MudNavLink Href="/admin/empleados" Class="kpg-nav-child">
                    @L["Nav_Resources"]
                </MudNavLink>
                <MudNavLink Href="/admin/clientes" Class="kpg-nav-child">
                    @L["Nav_ClientsProjects"]
                </MudNavLink>
                <MudNavLink Href="/solicitudes-excepcion" Class="kpg-nav-child">
                    @L["Nav_ExceptionRequests"]
                </MudNavLink>
                <MudNavLink Href="/admin/bitacora" Class="kpg-nav-child">
                    @L["Nav_AdminBitacora"]
                </MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="@L["Nav_Params"]"
                         Icon="@Icons.Material.Filled.Settings"
                         @bind-Expanded="_parametrosExpanded">
                <MudNavLink Href="/admin/parametros/configuracion" Class="kpg-nav-child">
                    @L["Nav_GeneralConfig"]
                </MudNavLink>
                <MudNavLink Href="/admin/parametros/modalidades" Class="kpg-nav-child">
                    @L["Nav_Modalities"]
                </MudNavLink>
                <MudNavLink Href="/admin/parametros/lugares" Class="kpg-nav-child">
                    @L["Nav_WorkPlaces"]
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

</MudNavMenu>

@code {
    private bool _reportesExpanded   = false;
    private bool _adminExpanded      = false;
    private bool _parametrosExpanded = false;
}
