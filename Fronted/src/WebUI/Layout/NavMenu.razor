@inject KpgAuthStateProvider AuthProvider
@inject NavigationManager Navigation

<MudNavMenu Class="kpg-nav" Style="padding:8px 0;">

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home"
                        IconColor="Color.Secondary">
                Inicio
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.Empleado},{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")">
        <Authorized>
            <MudNavLink Href="/registro"
                        Icon="@Icons.Material.Filled.EditCalendar"
                        IconColor="Color.Secondary">
                Registro
            </MudNavLink>
            <MudNavLink Href="/mis-registros"
                        Icon="@Icons.Material.Filled.History"
                        IconColor="Color.Secondary">
                Mis Registros
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.Supervisor},{Roles.Gerente},{Roles.Admin}")">
        <Authorized>
            <MudNavLink Href="/dashboard"
                        Icon="@Icons.Material.Filled.Dashboard"
                        IconColor="Color.Secondary">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/reportes"
                        Icon="@Icons.Material.Filled.BarChart"
                        IconColor="Color.Secondary">
                Reportes
            </MudNavLink>
            <MudNavLink Href="/notificaciones"
                        Icon="@Icons.Material.Filled.Notifications"
                        IconColor="Color.Secondary">
                Notificaciones
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.Supervisor},{Roles.Gerente}")">
        <Authorized>
            <MudNavLink Href="/bitacora"
                        Icon="@Icons.Material.Filled.ManageSearch"
                        IconColor="Color.Secondary">
                Bitácora
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@Roles.Admin">
        <Authorized>
            <MudNavLink Href="/admin/usuarios"
                        Icon="@Icons.Material.Filled.AdminPanelSettings"
                        IconColor="Color.Secondary">
                Administración
            </MudNavLink>
            <MudNavLink Href="/admin/empleados"
                        Icon="@Icons.Material.Filled.People"
                        IconColor="Color.Secondary">
                Empleados
            </MudNavLink>
            <MudNavLink Href="/admin/clientes"
                        Icon="@Icons.Material.Filled.Business"
                        IconColor="Color.Secondary">
                Clientes
            </MudNavLink>
            <MudNavLink Href="/solicitudes-excepcion"
                        Icon="@Icons.Material.Filled.PendingActions"
                        IconColor="Color.Secondary">
                Solicitudes
            </MudNavLink>
            <MudNavLink Href="/admin/bitacora"
                        Icon="@Icons.Material.Filled.ManageSearch"
                        IconColor="Color.Secondary">
                Bitácora
            </MudNavLink>
            <MudNavLink Href="/admin/parametros"
                        Icon="@Icons.Material.Filled.Settings"
                        IconColor="Color.Secondary">
                Parámetros
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

</MudNavMenu>
