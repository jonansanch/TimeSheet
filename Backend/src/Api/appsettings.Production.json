{
  "FrontendBaseUrl": "https://timesheet-v1-d7f0bhgnf5a9c6cc.centralus-01.azurewebsites.net",
  "Smtp": {
    "Host": "",
    "Port": 587,
    "FromAddress": "noreply@kpg-timesheet.com",
    "FromName": "KPG Timesheet",
    "UserName": "",
    "Password": "",
    "EnableSsl": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/kpg-timesheet-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
